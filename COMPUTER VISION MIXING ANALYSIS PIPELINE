from PyQt5.QtCore import QObject, pyqtSignal

class ProcessingEngine(QObject):
    """
    Orchestrates the full CV pipeline.
    Receives frames from VideoThread, processes them, and emits results.
    """
    frame_processed = pyqtSignal(object, object, object)  
    # Emits: (original_frame, rmi_results, bubbles)

    def __init__(self, processing_state, parent=None):
        super().__init__(parent)
        self.state = processing_state

        # Ensure bubble tracker exists in state
        if not hasattr(self.state, "bubble_tracker"):
            self.state.bubble_tracker = BubbleTracker(TrackerConfig())

    def process_frame(self, frame):
        """
        Runs the complete image processing pipeline on a single frame.
        Updates state with latest metrics and plot images.
        """
        if frame is None:
            return  # Safety check
    
        # -------------------------------------------------------------------------
        # Step 1: Preprocessing
        # -------------------------------------------------------------------------
        preprocessed = preprocess_frame(frame, self.state)
    
        # -------------------------------------------------------------------------
        # Step 2: RMI computation
        # -------------------------------------------------------------------------
        rmi_results = compute_rmi_results(preprocessed, self.state)
        self.state.last_rmi_results = rmi_results
    
        # Append to RMI history for plotting
        if not hasattr(self.state, "rmi_history"):
            self.state.rmi_history = []
        self.state.rmi_history.append(rmi_results)
        if len(self.state.rmi_history) > PLOT_CONFIG["history_length"]:
            self.state.rmi_history.pop(0)
    
        # -------------------------------------------------------------------------
        # Step 3: Bubble detection/tracking
        # -------------------------------------------------------------------------
        bubbles = process_bubbles(preprocessed, self.state)
        self.state.last_bubbles = bubbles
    
        if not hasattr(self.state, "bubble_history"):
            self.state.bubble_history = []
        self.state.bubble_history.extend(bubbles)
        if len(self.state.bubble_history) > 200:  # limit history length
            self.state.bubble_history = self.state.bubble_history[-200:]
    
    
        # -------------------------------------------------------------------------
        # Step 5: Generate plots (Section 9.4)
        # -------------------------------------------------------------------------
        self.state.last_rmi_plot = render_rmi_plot(self.state)
        self.state.last_bubble_plot = render_bubble_plot(self.state)
        self.state.last_roi_progression = render_roi_progression(self.state)
    
        # -------------------------------------------------------------------------
        # Step 6: Store last raw frame
        # -------------------------------------------------------------------------
        self.state.last_frame = frame
    
        # -------------------------------------------------------------------------
        # Step 7: Emit results for UI
        # -------------------------------------------------------------------------
        self.frame_processed.emit(frame, rmi_results, bubbles)


     
