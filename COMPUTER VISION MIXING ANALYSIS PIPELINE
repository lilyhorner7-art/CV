import cv2
import numpy as np

# =============================================================================
# RMI Plot
# =============================================================================
def render_rmi_plot(state):
    """
    Render the RMI history plot as a NumPy BGR image.
    Expects state.rmi_history to be a list/array of floats.
    """
    width = DASHBOARD_CONFIG["quadrant_width"]
    height = DASHBOARD_CONFIG["quadrant_height"]

    canvas = create_plot_canvas(width, height)
    draw_plot_grid(canvas)

    if not hasattr(state, "rmi_history") or len(state.rmi_history) < 2:
        return canvas

    # Plot line
    left = PLOT_CONFIG["margin_left"]
    right = width - PLOT_CONFIG["margin_right"]
    top = PLOT_CONFIG["margin_top"]
    bottom = height - PLOT_CONFIG["margin_bottom"]

    # Normalize RMI values to fit in plot area
    values = np.array(state.rmi_history[-PLOT_CONFIG["history_length"]:], dtype=np.float32)
    min_val, max_val = np.min(values), np.max(values)
    if max_val == min_val:
        max_val += 1e-6  # avoid div by zero

    x_step = (right - left) / max(1, len(values) - 1)
    points = []
    for i, val in enumerate(values):
        x = int(left + i * x_step)
        y = int(bottom - (val - min_val) / (max_val - min_val) * (bottom - top))
        points.append((x, y))

    cv2.polylines(canvas, [np.array(points, dtype=np.int32)], isClosed=False, color=(0, 255, 0), thickness=2)

    return canvas


# =============================================================================
# Bubble Plot
# =============================================================================
def render_bubble_plot(state):
    """
    Render bubble positions/sizes as a scatter plot.
    Expects state.bubble_history to be a list of (x, y, radius) tuples.
    """
    width = DASHBOARD_CONFIG["quadrant_width"]
    height = DASHBOARD_CONFIG["quadrant_height"]

    canvas = create_plot_canvas(width, height)
    draw_plot_grid(canvas)

    if not hasattr(state, "bubble_history") or len(state.bubble_history) == 0:
        return canvas

    # Draw bubbles
    for (x, y, r) in state.bubble_history[-200:]:  # limit to last N bubbles
        cv2.circle(canvas, (int(x), int(y)), int(r), (0, 200, 255), 1)

    return canvas


# =============================================================================
# ROI Progression Plot
# =============================================================================
def render_roi_progression(state):
    """
    Render ROI progression as a heatmap-like plot.
    Expects state.roi_progression to be a 2D NumPy array (float or int).
    """
    width = DASHBOARD_CONFIG["quadrant_width"]
    height = DASHBOARD_CONFIG["quadrant_height"]

    canvas = create_plot_canvas(width, height)
    draw_plot_grid(canvas)

    if not hasattr(state, "roi_progression") or state.roi_progression is None:
        return canvas

    # Normalize ROI progression to 0–255
    roi_data = state.roi_progression.astype(np.float32)
    min_val, max_val = np.min(roi_data), np.max(roi_data)
    if max_val == min_val:
        max_val += 1e-6
    norm_data = ((roi_data - min_val) / (max_val - min_val) * 255).astype(np.uint8)

    # Apply colormap
    heatmap = cv2.applyColorMap(norm_data, cv2.COLORMAP_JET)

    # Fit into plot area
    fitted = fit_image(heatmap, (width, height))
    return fitted

