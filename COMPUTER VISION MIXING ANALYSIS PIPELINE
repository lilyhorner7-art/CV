    minimum_area: float = 0.0

    maximum_area: float = 0.0

    mean_velocity: float = 0.0

    maximum_velocity: float = 0.0

    mean_age: float = 0.0

    maximum_age: int = 0

    longest_track: int | None = None

    bubble_rate: float = 0.0


# -----------------------------------------------------------------------------
# Area Statistics
# -----------------------------------------------------------------------------

def compute_bubble_area_statistics():
    """
    Computes statistics of the currently tracked
    bubble areas.
    """

    areas = [

        track["area"]

        for track in STATE["tracks"].values()

    ]

    if len(areas) == 0:

        return {

            "mean": 0.0,

            "median": 0.0,

            "minimum": 0.0,

            "maximum": 0.0

        }

    return {

        "mean": float(np.mean(areas)),

        "median": float(np.median(areas)),

        "minimum": float(np.min(areas)),

        "maximum": float(np.max(areas))

    }


# -----------------------------------------------------------------------------
# Velocity Statistics
# -----------------------------------------------------------------------------

def compute_bubble_velocity_statistics():
    """
    Computes statistics of tracked bubble velocities.
    """

    velocities = [

        track["velocity"]

        for track in STATE["tracks"].values()

    ]

    if len(velocities) == 0:

        return {

            "mean": 0.0,

            "maximum": 0.0

        }

    return {

        "mean": float(np.mean(velocities)),

        "maximum": float(np.max(velocities))

    }


# -----------------------------------------------------------------------------
# Age Statistics
# -----------------------------------------------------------------------------

def compute_bubble_age_statistics():
    """
    Computes statistics of bubble track ages.
    """

    ages = [

        track["age"]

        for track in STATE["tracks"].values()

    ]

    if len(ages) == 0:

        return {

            "mean": 0.0,

            "maximum": 0,

            "longest_track": None

        }

    longest_track = max(

        STATE["tracks"].values(),

        key=lambda track: track["age"]

    )["id"]

    return {

        "mean": float(np.mean(ages)),

        "maximum": int(np.max(ages)),

        "longest_track": longest_track

    }


# -----------------------------------------------------------------------------
# Bubble Generation Rate
# -----------------------------------------------------------------------------

def compute_bubble_generation_rate():
    """
    Computes the average bubble generation rate
    (detections per second).
    """

    if len(STATE["t"]) < 2:

        return 0.0

    duration = STATE["t"][-1] - STATE["t"][0]

    if duration <= 0:

        return 0.0

    total_detections = np.sum(

        STATE["bubble_history"]

    )

    return float(

        total_detections / duration

    )


# -----------------------------------------------------------------------------
# Complete Bubble Analysis
# -----------------------------------------------------------------------------

def compute_bubble_statistics():
    """
    Computes a complete statistical summary of
    bubble behaviour.

    Returns
    -------
    BubbleStatistics
    """

    area = compute_bubble_area_statistics()

    velocity = compute_bubble_velocity_statistics()

    age = compute_bubble_age_statistics()

    statistics = BubbleStatistics(

        active_tracks=len(STATE["tracks"]),

        total_tracks=STATE["next_track_id"] - 1,

        total_detections=int(

            np.sum(

                STATE["bubble_history"]

            )

        ),

        mean_area=area["mean"],

        median_area=area["median"],

        minimum_area=area["minimum"],

        maximum_area=area["maximum"],

        mean_velocity=velocity["mean"],

        maximum_velocity=velocity["maximum"],

        mean_age=age["mean"],

        maximum_age=age["maximum"],

        longest_track=age["longest_track"],

        bubble_rate=compute_bubble_generation_rate()

    )

    STATE["bubble_statistics"] = {

        "active_tracks": statistics.active_tracks,

        "mean_area": statistics.mean_area,

        "largest_area": statistics.maximum_area,

        "smallest_area": statistics.minimum_area,

        "mean_age": statistics.mean_age,

        "max_age": statistics.maximum_age

    }

    return statistics


# -----------------------------------------------------------------------------
# Bubble Analysis Summary
# -----------------------------------------------------------------------------

def summarise_bubble_analysis():
    """
    Executes the complete bubble analysis.

    Returns
    -------
    BubbleStatistics
    """

    return compute_bubble_statistics()

