# =============================================================================
# Run Calibration
# =============================================================================

def run_calibration(video_source, patch_size=40):
    """
    Launches the PyQt5 calibration workflow.

    Parameters
    ----------
    video_source : int | str
        Camera index, video file path, or virtual camera device.
    patch_size : int
        Calibration sampling patch size.

    Returns
    -------
    int
        Qt application exit code.
    """

    # -------------------------------------------------------------------------
    # Create application instance
    # -------------------------------------------------------------------------
    app = QApplication.instance()
    if app is None:
        app = QApplication(sys.argv)

    # -------------------------------------------------------------------------
    # Create shared calibration state
    # -------------------------------------------------------------------------
    state = CalibrationState()
    state.source_video = video_source
    state.patch_size = patch_size

    # -------------------------------------------------------------------------
    # Create processing engine
    # -------------------------------------------------------------------------
    processing_engine = ProcessingEngine(state)

    # -------------------------------------------------------------------------
    # Create video thread (engine passed as first arg)
    # -------------------------------------------------------------------------
    video_thread = VideoThread(processing_engine, video_source)

    # -------------------------------------------------------------------------
    # Create calibration window
    # -------------------------------------------------------------------------
    window = CalibrationWindow(video_thread, state)

    # -------------------------------------------------------------------------
    # Create calibration controller
    # -------------------------------------------------------------------------
    controller = CalibrationController(state)

    # -------------------------------------------------------------------------
    # Connect signals
    # -------------------------------------------------------------------------
    video_thread.frame_ready.connect(window.update_frame)
    processing_engine.frame_processed.connect(controller.handle_processed_frame)

    # -------------------------------------------------------------------------
    # Show window and start video thread
    # -------------------------------------------------------------------------
    window.show()
    video_thread.start()

    # -------------------------------------------------------------------------
    # Execute Qt application loop
    # -------------------------------------------------------------------------
    return app.exec_()


