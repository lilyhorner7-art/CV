# -----------------------------------------------------------------------------
# Video Source
# -----------------------------------------------------------------------------

class VideoSource:
    """
    Unified interface for

        • MP4 files
        • USB cameras
        • Virtual cameras

    Every processing function only communicates with this class.
    """

    def __init__(self, config: VideoSourceConfig):

        self.config = config

        self.cap = cv2.VideoCapture(config.source)

        if not self.cap.isOpened():

            raise RuntimeError(
                "Unable to open video source."
            )

        self.fps = self.cap.get(
            cv2.CAP_PROP_FPS
        )

        if self.fps <= 1:

            self.fps = 30.0

        self.frame_count = int(
            self.cap.get(cv2.CAP_PROP_FRAME_COUNT)
        )

    # -------------------------------------------------------------------------

    def read(self):
        """
        Reads the next frame.

        Returns
        -------
        success

        frame

        timestamp
        """

        success, frame = self.cap.read()

        if not success:

            if self.config.loop_video:

                self.cap.set(
                    cv2.CAP_PROP_POS_FRAMES,
                    0
                )

                success, frame = self.cap.read()

            else:

                return False, None, None

        if self.config.flip_horizontal:

            frame = cv2.flip(frame, 1)

        if self.config.flip_vertical:

            frame = cv2.flip(frame, 0)

        if self.config.resize_to is not None:

            frame = cv2.resize(
                frame,
                self.config.resize_to
            )

        timestamp = (
            self.cap.get(
                cv2.CAP_PROP_POS_MSEC
            )
            / 1000.0
        )

        return True, frame, timestamp

    # -------------------------------------------------------------------------

    def release(self):

        self.cap.release()

