class BubbleAnalyzer:
    """
    Converts bubble tracks into scientific measurements.
    """


    def __init__(self):

        self.history = []



    # =========================================================================
    # Area Statistics
    # =========================================================================


    def calculate_size_statistics(
        self,
        tracks
    ):
        """
        Calculates bubble size statistics.

        Returns
        -------
        dict
        """

        areas = [

            track.area

            for track in tracks

        ]


        diameters = [

            track.equivalent_diameter

            for track in tracks

        ]


        if len(areas) == 0:

            return {


                "mean_area":0,

                "median_area":0,

                "minimum_area":0,

                "maximum_area":0,

                "mean_diameter":0,

                "diameters":[]

            }



        return {


            "mean_area":

                float(np.mean(areas)),


            "median_area":

                float(np.median(areas)),


            "minimum_area":

                float(np.min(areas)),


            "maximum_area":

                float(np.max(areas)),


            "mean_diameter":

                float(np.mean(diameters)),


            "diameters":

                diameters

        }



    # =========================================================================
    # Velocity Statistics
    # =========================================================================


    def calculate_velocity_statistics(
        self,
        tracks
    ):
        """
        Calculates bubble velocity statistics.
        """


        velocities = []


        for track in tracks:


            if len(track.velocity_history) > 0:


                velocities.extend(

                    track.velocity_history

                )



        if len(velocities) == 0:

            return {


                "mean_velocity":0,

                "maximum_velocity":0,

                "velocity_distribution":[]

            }



        return {


            "mean_velocity":

                float(np.mean(velocities)),


            "maximum_velocity":

                float(np.max(velocities)),


            "velocity_distribution":

                velocities

        }



    # =========================================================================
    # Residence Time
    # =========================================================================


    def calculate_residence_time(
        self,
        tracks
    ):
        """
        Calculates average bubble lifetime.

        Residence time:

            final timestamp - initial timestamp

        """


        residence_times = []


        for track in tracks:


            if len(track.timestamp_history) < 2:

                continue



            residence_times.append(

                track.timestamp_history[-1]

                -

                track.timestamp_history[0]

            )



        if len(residence_times)==0:

            return 0



        return float(

            np.mean(residence_times)

        )



    # =========================================================================
    # Bubble Frequency
    # =========================================================================


    def calculate_frequency(
        self,
        new_tracks,
        elapsed_time
    ):
        """
        Calculates bubble generation frequency.

        bubbles / second

        """


        if elapsed_time <= 0:

            return 0



        return (

            len(new_tracks)

            /

            elapsed_time

        )



    # =========================================================================
    # Tracking Statistics
    # =========================================================================


    def calculate_track_statistics(
        self,
        tracks
    ):
        """
        Calculates track quality metrics.
        """


        ages = [

            track.age

            for track in tracks

        ]



        if len(ages)==0:

            return {


                "mean_track_age":0,

                "active_track_count":0

            }



        return {


            "mean_track_age":

                float(np.mean(ages)),


            "active_track_count":

                len(tracks)

        }



    # =========================================================================
    # Complete Analysis Pipeline
    # =========================================================================


    def analyse(
        self,
        tracked_results,
        validation_results,
        elapsed_time
    ):
        """
        Complete bubble analysis pipeline.

        Parameters
        ----------

        tracked_results :
            TrackedBubbleResults


        validation_results :
            BubbleValidationManager


        elapsed_time :
            experiment time


        Returns
        -------

        BubbleAnalysisResults

        """



        tracks = list(

            tracked_results.active_tracks.values()

        )



        size = self.calculate_size_statistics(
            tracks
        )


        velocity = self.calculate_velocity_statistics(
            tracks
        )


        residence = self.calculate_residence_time(
            tracks
        )


        frequency = self.calculate_frequency(

            tracked_results.new_tracks,

            elapsed_time

        )


        tracking = self.calculate_track_statistics(
            tracks
        )



        if validation_results:


            validation_stats = (

                validation_results.get_statistics()

            )

        else:

            validation_stats = {

                "accepted":0,

                "rejected":0

            }



        result = BubbleAnalysisResults(


            active_bubbles=len(tracks),


            total_bubbles_detected=(

                validation_stats["accepted"]

                +

                validation_stats["rejected"]

            ),


            validated_bubbles=(

                validation_stats["accepted"]

            ),


            rejected_bubbles=(

                validation_stats["rejected"]

            ),


            mean_area=size["mean_area"],


            median_area=size["median_area"],


            minimum_area=size["minimum_area"],


            maximum_area=size["maximum_area"],


            mean_diameter=size["mean_diameter"],


            diameter_distribution=size["diameters"],



            mean_velocity=velocity["mean_velocity"],


            maximum_velocity=velocity["maximum_velocity"],


            velocity_distribution=velocity["velocity_distribution"],



            bubble_frequency=frequency,


            mean_residence_time=residence,


            mean_track_age=tracking["mean_track_age"],


            active_track_count=tracking["active_track_count"]

        )



        self.history.append(result)



        return result
    
