# =============================================================================
# 1D Intensity Line Profile
# =============================================================================

def compute_line_profile(
    gray_roi: np.ndarray,
    axis: int
) -> np.ndarray:
    """
    Computes the one-dimensional intensity profile of a grayscale ROI.

    Parameters
    ----------
    gray_roi : ndarray

        Grayscale ROI.

    axis : int

        axis = 0
            Average each column.

        axis = 1
            Average each row.

    Returns
    -------
    ndarray

        One-dimensional intensity profile.
    """

    if gray_roi is None:
        return np.array([], dtype=np.float32)

    if gray_roi.size == 0:
        return np.array([], dtype=np.float32)

    if axis not in (0, 1):
        raise ValueError("axis must be either 0 or 1.")

    profile = np.mean(
        gray_roi.astype(np.float32),
        axis=axis
    )

    return profile


# =============================================================================
# Sigma Calculation
# =============================================================================

def compute_sigma(
    gray_roi: np.ndarray,
    axis: int
) -> float:
    """
    Computes the standard deviation of the one-dimensional
    intensity profile.

    Parameters
    ----------
    gray_roi : ndarray

        Grayscale ROI.

    axis : int

        Profile direction.

    Returns
    -------
    float

        Sigma value.
    """

    profile = compute_line_profile(
        gray_roi,
        axis
    )

    if profile.size == 0:
        return 0.0

    return float(np.std(profile))


# =============================================================================
# Baseline Sigma
# =============================================================================

def compute_baseline_sigma(
    interface_roi: np.ndarray,
    axis: int
) -> float:
    """
    Computes the experimental baseline sigma using the
    interface ROI.

    This value is used as the reference for all subsequent
    Relative Mixing Index calculations.

    Parameters
    ----------
    interface_roi : ndarray

        Interface ROI captured during baseline acquisition.

    axis : int

        Profile direction.

    Returns
    -------
    float

        Reference sigma.
    """

    sigma_reference = compute_sigma(
        interface_roi,
        axis
    )

    return float(sigma_reference)


# =============================================================================
# Relative Mixing Index (RMI)
# =============================================================================

def compute_rmi(
    gray_roi: np.ndarray,
    sigma_reference: Optional[float],
    axis: int
) -> Tuple[float, float]:
    """
    Computes the Relative Mixing Index (RMI).

    Equation
    --------

        RMI = 1 - (σ_mix / σ_reference)

    where

        σ_mix       = standard deviation of the current ROI

        σ_reference = baseline interface standard deviation

    Parameters
    ----------
    gray_roi : ndarray

        Current grayscale ROI.

    sigma_reference : float

        Experimental baseline sigma.

    axis : int

        Profile direction.

    Returns
    -------
    tuple

        rmi : float

            Relative Mixing Index.

        sigma_mix : float

            Current sigma.
    """

    sigma_mix = compute_sigma(
        gray_roi,
        axis
    )

    if sigma_reference is None:
        return 0.0, sigma_mix

    if sigma_reference <= 0:
        return 0.0, sigma_mix

    rmi = 1.0 - (sigma_mix / sigma_reference)

    rmi = float(np.clip(
        rmi,
        0.0,
        1.0
    ))

    return rmi, sigma_mix


# =============================================================================
# RMI Convenience Function
# =============================================================================

def analyse_mixing_roi(
    roi: np.ndarray,
    grayscale_weights,
    sigma_reference: float,
    axis: int
) -> dict:
    """
    Complete RMI analysis pipeline for a single ROI.

    Workflow
    --------

    1. Convert ROI to custom grayscale.

    2. Compute line profile.

    3. Compute sigma.

    4. Compute Relative Mixing Index.

    Parameters
    ----------
    roi : ndarray

        Input BGR ROI.

    grayscale_weights : tuple

        Optimised RGB weights.

    sigma_reference : float

        Baseline sigma.

    axis : int

        Profile direction.

    Returns
    -------
    dict

        {
            "gray",
            "profile",
            "sigma",
            "rmi"
        }
    """

    gray = grayscale_with_weights(
        roi,
        grayscale_weights
    )

    profile = compute_line_profile(
        gray,
        axis
    )

    sigma = compute_sigma(
        gray,
        axis
    )

    rmi, _ = compute_rmi(
        gray,
        sigma_reference,
        axis
    )

    return {

        "gray": gray,

        "profile": profile,

        "sigma": sigma,

        "rmi": rmi

    }


# =============================================================================
# Multiple ROI Analysis
# =============================================================================

def analyse_multiple_rois(
    frame: np.ndarray,
    roi_definitions: dict,
    grayscale_weights,
    sigma_reference: float,
    axis: int
) -> dict:
    """
    Computes the Relative Mixing Index for every experimental ROI.

    Parameters
    ----------
    frame : ndarray

        Current BGR frame.

    roi_definitions : dict

        Dictionary containing all experimental ROIs.

    Returns
    -------
    dict

        Dictionary containing the analysis results for every ROI.
    """

    results = {}

    for roi_name, roi in roi_definitions.items():

        roi_image = extract_roi(
            frame,
            roi
        )

        if roi_image.size == 0:
            continue

        results[roi_name] = analyse_mixing_roi(
            roi_image,
            grayscale_weights,
            sigma_reference,
            axis
        )

    return results

