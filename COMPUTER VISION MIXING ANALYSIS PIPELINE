# -----------------------------------------------------------------------------
# Convert Summary Dictionary to DataFrame
# -----------------------------------------------------------------------------
def summary_dictionary_to_dataframe(
    summary
):
    """
    Converts experiment summary dictionary
    into an exportable dataframe.

    Returns
    -------
    pandas.DataFrame
    """

    rows = []


    def flatten(dictionary, prefix=""):


        for key, value in dictionary.items():


            if isinstance(
                value,
                dict
            ):

                flatten(

                    value,

                    prefix +
                    key +
                    "_"

                )


            else:

                rows.append({

                    "Parameter":

                        prefix + key,

                    "Value":

                        value

                })


    flatten(summary)


    return pd.DataFrame(rows)

