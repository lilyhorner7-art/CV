from typing import Tuple, Optional

# =============================================================================
# ROI Validation
# =============================================================================

def validate_roi(
    roi: Tuple[int, int, int, int],
    image_shape: Tuple[int, ...]
) -> Optional[Tuple[int, int, int, int]]:
    """
    Validates and clips a rectangular ROI so that it always lies
    within the image boundaries.

    Parameters
    ----------
    roi : tuple
        ROI coordinates in the form:

            (y1, y2, x1, x2)

    image_shape : tuple
        Shape of the input image.

    Returns
    -------
    tuple or None

        Returns a corrected ROI if valid.

        Returns None if the ROI has zero area.
    """

    if roi is None:
        return None

    y1, y2, x1, x2 = roi

    image_height, image_width = image_shape[:2]

    # ---------------------------------------------------------
    # Clip coordinates to image boundaries
    # ---------------------------------------------------------

    y1 = max(0, min(int(y1), image_height))
    y2 = max(0, min(int(y2), image_height))

    x1 = max(0, min(int(x1), image_width))
    x2 = max(0, min(int(x2), image_width))

    # ---------------------------------------------------------
    # Ensure correct ordering
    # ---------------------------------------------------------

    if y2 < y1:
        y1, y2 = y2, y1

    if x2 < x1:
        x1, x2 = x2, x1

    # ---------------------------------------------------------
    # Reject empty ROIs
    # ---------------------------------------------------------

    if (y2 - y1) <= 0:
        return None

    if (x2 - x1) <= 0:
        return None

    return (y1, y2, x1, x2)


# =============================================================================
# ROI Extraction
# =============================================================================

def extract_roi(
    image: np.ndarray,
    roi: Tuple[int, int, int, int]
) -> np.ndarray:
    """
    Safely extracts a rectangular Region of Interest (ROI).

    ROI Format
    ----------
    (y1, y2, x1, x2)

    Parameters
    ----------
    image : ndarray
        Input BGR or grayscale image.

    roi : tuple
        ROI coordinates.

    Returns
    -------
    ndarray

        Extracted ROI.

        If the ROI is invalid an empty ndarray is returned.
    """

    if image is None:
        return np.empty((0, 0), dtype=np.uint8)

    if image.size == 0:
        return np.empty((0, 0), dtype=np.uint8)

    validated_roi = validate_roi(roi, image.shape)

    if validated_roi is None:
        return np.empty((0, 0), dtype=image.dtype)

    y1, y2, x1, x2 = validated_roi

    return image[y1:y2, x1:x2].copy()


# =============================================================================
# ROI Geometry
# =============================================================================

def roi_width(
    roi: Tuple[int, int, int, int]
) -> int:
    """
    Returns the ROI width in pixels.
    """

    _, _, x1, x2 = roi

    return int(x2 - x1)


def roi_height(
    roi: Tuple[int, int, int, int]
) -> int:
    """
    Returns the ROI height in pixels.
    """

    y1, y2, _, _ = roi

    return int(y2 - y1)


def roi_centre(
    roi: Tuple[int, int, int, int]
) -> Tuple[int, int]:
    """
    Returns the centre of an ROI.

    Returns
    -------
    tuple

        (x, y)
    """

    y1, y2, x1, x2 = roi

    centre_x = (x1 + x2) // 2
    centre_y = (y1 + y2) // 2

    return centre_x, centre_y


# =============================================================================
# ROI Scaling
# =============================================================================

def resize_roi_display(
    roi_image: np.ndarray,
    scale_factor: float = 4.0,
    interpolation: int = cv2.INTER_NEAREST
) -> np.ndarray:
    """
    Enlarges an ROI for GUI display only.

    This function DOES NOT change the image used for processing.
    It is used to display enlarged ROIs within the Version 6
    scientific dashboard.

    Parameters
    ----------
    roi_image : ndarray

        ROI extracted from the original frame.

    scale_factor : float

        Display scaling factor.

    interpolation : int

        OpenCV interpolation method.

    Returns
    -------
    ndarray

        Enlarged ROI.
    """

    if roi_image is None:
        return np.empty((0, 0), dtype=np.uint8)

    if roi_image.size == 0:
        return roi_image

    height, width = roi_image.shape[:2]

    new_width = max(1, int(width * scale_factor))
    new_height = max(1, int(height * scale_factor))

    return cv2.resize(
        roi_image,
        (new_width, new_height),
        interpolation=interpolation
    )


