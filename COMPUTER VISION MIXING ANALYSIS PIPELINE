# =============================================================================
# SECTION 6.4B
# Validation Manager
# =============================================================================

class BubbleValidationManager:
    """
    Human validation interface for bubble detection.

    Controls:

    Y  -> Accept bubble

    N  -> Reject bubble

    ESC -> Skip validation


    """



    def __init__(self):

        self.pending_validation = None


        self.validation_history = []


        self.accepted_count = 0


        self.rejected_count = 0



    # -------------------------------------------------------------------------
    # Create validation request
    # -------------------------------------------------------------------------

    def request_validation(
        self,
        track,
        frame_number,
        timestamp
    ):
        """
        Creates a validation request.

        """

        self.pending_validation = BubbleValidation(

            track_id=track.track_id,

            frame_number=frame_number,

            timestamp=timestamp,

            centroid=track.centroid,

            area=track.area,

            diameter=track.equivalent_diameter,

            confidence=(
                track.confidence_history[-1]
                if len(track.confidence_history) > 0
                else 0
            )

        )


        return self.pending_validation



    # -------------------------------------------------------------------------
    # Process user response
    # -------------------------------------------------------------------------

    def validate(
        self,
        decision
    ):
        """
        Stores operator decision.

        Parameters
        ----------

        decision :
            ValidationDecision

        """


        if self.pending_validation is None:

            return None



        self.pending_validation.decision = decision



        # Update counters

        if decision == ValidationDecision.ACCEPTED:

            self.accepted_count += 1


        elif decision == ValidationDecision.REJECTED:

            self.rejected_count += 1



        self.validation_history.append(

            self.pending_validation

        )


        result = self.pending_validation


        self.pending_validation = None


        return result



    # -------------------------------------------------------------------------
    # Validation statistics
    # -------------------------------------------------------------------------

    def get_statistics(self):
        """
        Returns validation statistics.
        """

        total = (

            self.accepted_count

            +

            self.rejected_count

        )


        if total == 0:

            accuracy = 0


        else:

            accuracy = (

                self.accepted_count /

                total

            )


        return {


            "total_validated":

                total,


            "accepted":

                self.accepted_count,


            "rejected":

                self.rejected_count,


            "acceptance_rate":

                accuracy

        }
    
# =============================================================================
# SECTION 6.4C
# Validation Decision Handler
# =============================================================================

def handle_validation_key(
    key,
    validation_manager
):
    """
    Handles operator response.

    Keyboard:

    Y -> Confirm bubble

    N -> Reject bubble

    ESC -> Ignore


    """


    if key == ord("y"):

        return validation_manager.validate(

            ValidationDecision.ACCEPTED

        )


    elif key == ord("n"):

        return validation_manager.validate(

            ValidationDecision.REJECTED

        )


    elif key == 27:

        return validation_manager.validate(

            ValidationDecision.REJECTED

        )


    return None

# =============================================================================
# SECTION 6.4D
# Validation Trigger Logic
# =============================================================================

def should_validate_bubble(
    track,
    config
):
    """
    Determines whether a bubble requires
    manual validation.

    Validation occurs when:

    • New bubble appears
    • Confidence is low
    • Bubble has unusual size


    """


    # New bubble

    if track.age <= 1:

        return True



    # Low confidence

    if (

        len(track.confidence_history)

        >

        0

    ):

        confidence = (

            track.confidence_history[-1]

        )


        if confidence < 0.5:

            return True



    return False

# =============================================================================
# Bubble validation integration inside BubbleTracker.update()
# =============================================================================

def update_validation_requests(
    self,
    matched_tracks,
    frame_number,
    timestamp
):
    """
    Sends tracked bubbles for manual validation when required.

    Parameters
    ----------
    matched_tracks : list
        List of active track IDs matched in the current frame.

    frame_number : int
        Current video frame index.

    timestamp : float
        Current video timestamp (seconds).

    """

    if self.validation_manager is None:
        return


    for track_id in matched_tracks:

        # ---------------------------------------------------------
        # Retrieve track object
        # ---------------------------------------------------------

        if track_id not in self.tracks:
            continue


        track = self.tracks[track_id]


        # ---------------------------------------------------------
        # Determine if validation is required
        # ---------------------------------------------------------

        if should_validate_bubble(
            track,
            self.validation_config
        ):


            self.validation_manager.request_validation(
                track,
                frame_number,
                timestamp
            )

