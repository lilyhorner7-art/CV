            self.convert_coordinates(
                x,
                y
            )
        )



        name = (
            self.selection_order[
                self.current_selection
            ]
        )


        width, height = (
            self.roi_sizes[name]
        )



        roi = ROIDefinition(

            name=name,

            centre=(

                image_x,

                image_y

            ),

            width=width,

            height=height

        )



        roi.calculate_coordinates()



        self.selected_rois[name] = roi



        self.current_selection += 1


        self.update_instructions()



    # -------------------------------------------------------------------------
    # Coordinate Conversion
    # -------------------------------------------------------------------------

    def convert_coordinates(
        self,
        x,
        y
    ):


        frame_h, frame_w = (
            self.current_frame.shape[:2]
        )


        widget_w = self.video_label.width()

        widget_h = self.video_label.height()



        return (

            int(
                x *
                frame_w /
                widget_w
            ),


            int(
                y *
                frame_h /
                widget_h
            )

        )



    # -------------------------------------------------------------------------
    # Draw ROIs
    # -------------------------------------------------------------------------

    def draw_roi_overlay(
        self,
        frame
    ):

        for name, roi in self.selected_rois.items():


            y1,y2,x1,x2 = (
                roi.coordinates
            )



            cv2.rectangle(

                frame,

                (x1,y1),

                (x2,y2),

                (0,255,0),

                2

            )



            cv2.circle(

                frame,

                roi.centre,

                5,

                (0,0,255),

                -1

            )


            cv2.putText(

                frame,

                name,

                (

                    x1,

                    y1-10

                ),

                cv2.FONT_HERSHEY_SIMPLEX,

                0.6,

                (0,255,0),

                2

            )



        return frame



    # -------------------------------------------------------------------------
    # Display
    # -------------------------------------------------------------------------

    def display_frame(
        self,
        frame
    ):


        rgb = cv2.cvtColor(

            frame,

            cv2.COLOR_BGR2RGB

        )


        h,w,c = rgb.shape



        image = QImage(

            rgb.data,

            w,

            h,

            rgb.strides[0],

            QImage.Format_RGB888

        )


        self.video_label.setPixmap(

            QPixmap.fromImage(
                image
            ).scaled(

                self.video_label.size(),

                Qt.KeepAspectRatio

            )

        )



    # -------------------------------------------------------------------------
    # Instructions
    # -------------------------------------------------------------------------

    def update_instructions(self):


        text = (

            "ROI SELECTION\n\n"

        )


        for i,name in enumerate(
            self.selection_order
        ):


            if name in self.selected_rois:

                status = "✓"


            elif i == self.current_selection:

                status = "← Select"


            else:

                status = ""



            text += (

                f"{i+1}. {name} {status}\n"

            )



        text += (

            "\nClick centre of each ROI."

            "\nROI dimensions are fixed."

        )


        self.instructions.setText(
            text
        )



    # -------------------------------------------------------------------------
    # Reset
    # -------------------------------------------------------------------------

    def reset_selection(self):

        self.selected_rois.clear()


        self.current_selection = 0


        self.update_instructions()



    # -------------------------------------------------------------------------
    # Confirm
    # -------------------------------------------------------------------------

    def confirm_selection(self):


        if len(
            self.selected_rois
        ) != 6:


            QMessageBox.warning(

                self,

                "ROI Selection",

                "Please select all six ROIs."

            )


            return



        self.state.roi_configuration.rois = (

            self.selected_rois

        )


        self.roi_complete.emit(
            self.state
        )


        self.close()



    # -------------------------------------------------------------------------
    # Cancel
    # -------------------------------------------------------------------------

    def cancel(self):

        self.roi_cancelled.emit()

        self.close()

