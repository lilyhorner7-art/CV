class CalibrationPreview(QWidget):
    """
    Interactive calibration preview widget.

    Displays:
        - Current video frame
        - Mouse location
        - Sampling patch
        - Calibration selections
        - Magnified patch

    Used by CalibrationWindow.
    """



    cursor_position_changed = pyqtSignal(
        int,
        int,
        np.ndarray
    )



    def __init__(
        self,
        patch_size=40,
        parent=None
    ):

        super().__init__(parent)


        self.patch_size = patch_size


        self.frame = None


        self.display_frame = None


        self.scale_factor = 1.0


        self.cursor_x = None

        self.cursor_y = None


        self.selected_points = []



        self.setMouseTracking(
            True
        )



    # -------------------------------------------------------------------------
    # Update Frame
    # -------------------------------------------------------------------------

    def update_frame(
        self,
        frame
    ):
        """
        Receives new video frame.
        """

        self.frame = frame.copy()


        self.update()



    # -------------------------------------------------------------------------
    # Mouse Movement
    # -------------------------------------------------------------------------

    def mouseMoveEvent(
        self,
        event
    ):
        """
        Tracks cursor location over video.
        """

        if self.frame is None:

            return


        x = event.position().x()

        y = event.position().y()



        image_x, image_y = (

            self.display_to_image_coordinates(

                x,

                y

            )

        )



        self.cursor_x = image_x

        self.cursor_y = image_y



        rgb = self.get_current_rgb()



        self.cursor_position_changed.emit(

            image_x,

            image_y,

            rgb

        )



        self.update()



    # -------------------------------------------------------------------------
    # Mouse Click
    # -------------------------------------------------------------------------

    def mousePressEvent(
        self,
        event
    ):
        """
        Emits converted image coordinates when
        user selects a calibration point.
        """

        if event.button() != Qt.LeftButton:

            return



        if self.frame is None:

            return



        x = event.position().x()

        y = event.position().y()



        image_x, image_y = (

            self.display_to_image_coordinates(

                x,

                y

            )

        )


        self.parent().video_clicked(

            event

        )



    # -------------------------------------------------------------------------
    # Coordinate Conversion
    # -------------------------------------------------------------------------

    def display_to_image_coordinates(
        self,
        x,
        y
    ):
        """
        Converts widget coordinates into
        original image coordinates.
        """

        if self.frame is None:

            return 0,0



        h,w = self.frame.shape[:2]


        widget_w = self.width()

        widget_h = self.height()



        scale_x = w / widget_w

        scale_y = h / widget_h



        return (

            int(x * scale_x),

            int(y * scale_y)

        )



    # -------------------------------------------------------------------------
    # RGB Sampling
    # -------------------------------------------------------------------------

    def get_current_rgb(
        self
    ):
        """
        Returns RGB value at cursor patch.

        Returns

        [R,G,B]
        """

        if self.frame is None:

            return np.zeros(
                3,
                dtype=np.float32
            )


        if self.cursor_x is None:

            return np.zeros(
                3,
                dtype=np.float32
            )



        patch = get_patch_mean_rgb(

            self.frame,

            (
                self.cursor_x,
                self.cursor_y
            ),

            self.patch_size

        )



        return patch



    # -------------------------------------------------------------------------
    # Paint Event
    # -------------------------------------------------------------------------

    def paintEvent(
        self,
        event
    ):
        """
        Draws calibration preview.
        """

        if self.frame is None:

            return



        frame = self.frame.copy()



        # -------------------------------------------------------------
        # Draw cursor patch
        # -------------------------------------------------------------

        if (

            self.cursor_x is not None

            and

            self.cursor_y is not None

        ):


            half = (
                self.patch_size // 2
            )


            cv2.rectangle(

                frame,

                (

                    self.cursor_x-half,

                    self.cursor_y-half

                ),

                (

                    self.cursor_x+half,

                    self.cursor_y+half

                ),

                (255,0,255),

                2

            )



        # -------------------------------------------------------------
        # Draw selected calibration points
        # -------------------------------------------------------------

        for point in self.selected_points:


            cv2.rectangle(

                frame,

                (

                    point.x-self.patch_size//2,

                    point.y-self.patch_size//2

                ),

                (

                    point.x+self.patch_size//2,

                    point.y+self.patch_size//2

                ),

                (0,255,0),

                2

            )



        # -------------------------------------------------------------
        # Convert image
        # -------------------------------------------------------------

        rgb = cv2.cvtColor(

            frame,

            cv2.COLOR_BGR2RGB

        )


        h,w,c = rgb.shape



        qt_image = QImage(

            rgb.data,

            w,

            h,

            rgb.strides[0],

            QImage.Format_RGB888

        )



        painter = QPainter(
            self
        )


        painter.drawPixmap(

            self.rect(),

            QPixmap.fromImage(
                qt_image
            )

        )



