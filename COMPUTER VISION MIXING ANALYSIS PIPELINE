    # ---------------------------------------------------------

    update_bubble_state(

        tracking_results,

        analysis_results

    )

    # ---------------------------------------------------------
    # Package results
    # ---------------------------------------------------------

    return BubbleProcessingResult(

        detections=detection_results,

        tracking=tracking_results,

        validation=validation_results,

        analysis=analysis_results,

        outlet_image=detection_results.source_image.copy(),

        threshold_image=detection_results.binary_image.copy()

