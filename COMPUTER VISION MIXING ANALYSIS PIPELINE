    """
    Extracts every processing ROI from the grayscale image.

    Returns
    -------
    dict
    """

    roi_gray = {}

    for roi_name, roi in STATE["rois"].items():

        roi_gray[roi_name] = extract_roi(
            gray_frame,
            roi
        )

    return roi_gray


# -----------------------------------------------------------------------------
# Validate Extracted ROIs
# -----------------------------------------------------------------------------

def validate_roi_images(roi_images):
    """
    Ensures every ROI contains image data.

    Raises
    ------
    ValueError
        If an ROI lies outside the image.
    """

    for roi_name, image in roi_images.items():

        if image is None:
            raise ValueError(
                f"{roi_name} ROI returned None."
            )

        if image.size == 0:
            raise ValueError(
                f"{roi_name} ROI is empty."
            )


