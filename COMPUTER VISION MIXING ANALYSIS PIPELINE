# VIDEO ACQUISITION THREAD
# =============================================================================
#
# Version 6 uses a dedicated QThread for video acquisition.
#
# The GUI never directly reads frames.
#
# Instead:
#
#       VideoThread
#             |
#             ↓
#       emits frame signal
#             |
#             ↓
#       Calibration Window
#       Main Dashboard
#
#
# This prevents the interface from freezing during video processing.
#
# =============================================================================


# =============================================================================
# Video Thread
# =============================================================================

from PyQt5.QtCore import QThread, pyqtSignal
import time

from PyQt5.QtCore import QThread, pyqtSignal, QMutex, QWaitCondition
import time


class VideoThread(QThread):
    """
    Worker thread that continuously reads frames from a VideoSource
    and sends them to the ProcessingEngine for processing.
    """

    # Signals
    frame_ready = pyqtSignal(object, float, int)       # raw frame, timestamp, frame_number
    frame_processed = pyqtSignal(object, float, int)   # processed frame, timestamp, frame_number
    video_finished = pyqtSignal()

    def __init__(self, processing_engine, video_source, parent=None):
        super().__init__(parent)

        # Store references
        self.engine = processing_engine
        self.video_source = video_source

        # Internal state
        self.frame_number = 0
        self.frame_interval = 1.0 / getattr(video_source, "fps", 30)  # fallback to 30 FPS
        self._running = True
        self._paused = False

        # Thread synchronization
        self._pause_mutex = QMutex()
        self._pause_condition = QWaitCondition()

    def run(self):
        """Main loop: read frames, process them, emit signals."""
        while self._running:
            # Handle pause
            self._pause_mutex.lock()
            while self._paused and self._running:
                self._pause_condition.wait(self._pause_mutex)
            self._pause_mutex.unlock()

            # Read frame from source (success, frame, timestamp)
            success, frame, timestamp = self.video_source.read()
            if not success:
                self.video_finished.emit()
                break

            self.frame_number += 1

            # Process the frame
            processed_frame = self.engine.process_frame(frame)

            # Emit raw and processed frames
            self.frame_ready.emit(frame, timestamp, self.frame_number)
            self.frame_processed.emit(processed_frame, timestamp, self.frame_number)

            # Sleep to maintain FPS
            self.msleep(int(self.frame_interval * 1000))

    def stop(self):
        """Stop the video thread gracefully."""
        self._running = False
        self.resume()  # In case it's paused
        self.wait()

    def pause(self):
        """Pause the video thread."""
        self._pause_mutex.lock()
        self._paused = True
        self._pause_mutex.unlock()

    def resume(self):
        """Resume the video thread."""
        self._pause_mutex.lock()
        self._paused = False
        self._pause_mutex.unlock()
        self._pause_condition.wakeAll()




