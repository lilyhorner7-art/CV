@dataclass
class SteadyStateResult:
    """
    Stores the steady-state analysis for a single ROI.
    """

    roi_name: str

    detected: bool

    frame: int | None

    time: float | None

    rmi: float | None

    rolling_standard_deviation: float | None


# -----------------------------------------------------------------------------
# Rolling Standard Deviation
# -----------------------------------------------------------------------------

def compute_rolling_standard_deviation(
    values,
    window=STEADY_STATE_WINDOW
):
    """
    Computes the rolling standard deviation.

    Parameters
    ----------
    values : sequence

    window : int

    Returns
    -------
    list
        Rolling standard deviation.
    """

    values = np.asarray(values, dtype=np.float64)

    if len(values) == 0:
        return []

    rolling_std = []

    for i in range(len(values)):

        start = max(0, i - window + 1)

        subset = values[start:i + 1]

        rolling_std.append(

            float(np.std(subset))

        )

    return rolling_std


# -----------------------------------------------------------------------------
# Detect Steady State
# -----------------------------------------------------------------------------

def detect_steady_state(
    roi_name,
    threshold=STEADY_STATE_THRESHOLD
):
    """
    Detects when an ROI reaches steady state.

    Steady state is defined as the first frame where the
    rolling standard deviation falls below the specified
    threshold.

    Parameters
    ----------
    roi_name : str

    threshold : float

    Returns
    -------
    SteadyStateResult
    """

    history = STATE["rmi_history"][roi_name]

    if len(history) < STEADY_STATE_WINDOW:

        return SteadyStateResult(

            roi_name=roi_name,

            detected=False,

            frame=None,

            time=None,

            rmi=None,

            rolling_standard_deviation=None

        )

    rolling_std = compute_rolling_standard_deviation(

        history,

        STEADY_STATE_WINDOW

    )

    for i in range(STEADY_STATE_WINDOW - 1, len(rolling_std)):

        if rolling_std[i] <= threshold:

            return SteadyStateResult(

                roi_name=roi_name,

                detected=True,

                frame=i + 1,

                time=STATE["t"][i],

                rmi=history[i],

                rolling_standard_deviation=rolling_std[i]

            )

    return SteadyStateResult(

        roi_name=roi_name,

        detected=False,

        frame=None,

        time=None,

        rmi=None,

        rolling_standard_deviation=None

    )


# -----------------------------------------------------------------------------
# Analyse All ROIs
# -----------------------------------------------------------------------------

def analyse_steady_state():
    """
    Performs steady-state analysis for every RMI ROI.

    Returns
    -------
    dict
        Dictionary of SteadyStateResult objects.
    """

    results = {}

    for roi_name in STATE["rmi_history"]:

        results[roi_name] = detect_steady_state(

            roi_name

        )

    return results


# -----------------------------------------------------------------------------
# Earliest Steady-State Location
# -----------------------------------------------------------------------------

def find_first_steady_state(results):
    """
    Determines which ROI reached steady state first.

    Parameters
    ----------
    results : dict

    Returns
    -------
    SteadyStateResult | None
    """

    detected = [

        result

        for result in results.values()

        if result.detected

    ]

    if len(detected) == 0:

        return None

    return min(

        detected,

        key=lambda result: result.time

    )


# -----------------------------------------------------------------------------
# Complete Steady-State Analysis
# -----------------------------------------------------------------------------

def update_steady_state_analysis():
    """
    Executes the complete steady-state analysis and updates
    the program state.

    Returns
    -------
    dict
    """

    results = analyse_steady_state()

    first = find_first_steady_state(

        results

    )

    if first is not None:

        STATE["steady_state"] = {

            "detected": True,

            "frame": first.frame,

            "time": first.time,

            "sigma": first.rolling_standard_deviation

        }

    else:

        STATE["steady_state"] = {

            "detected": False,

            "frame": None,

            "time": None,

            "sigma": None

        }

    return results

