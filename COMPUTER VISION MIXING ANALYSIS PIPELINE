def create_plot_canvas(width, height):
    """
    Creates an empty plotting canvas.
    """

    canvas = np.full(

        (height, width, 3),

        PLOT_CONFIG["background"],

        dtype=np.uint8

    )

    return canvas


# -----------------------------------------------------------------------------
# Draw Grid
# -----------------------------------------------------------------------------

def draw_plot_grid(image):
    """
    Draws a plotting grid.
    """

    h, w = image.shape[:2]

    left = PLOT_CONFIG["margin_left"]

    right = w - PLOT_CONFIG["margin_right"]

    top = PLOT_CONFIG["margin_top"]

    bottom = h - PLOT_CONFIG["margin_bottom"]

    # Outer border

    cv2.rectangle(

        image,

        (left, top),

        (right, bottom),

        PLOT_CONFIG["axis_colour"],

        1

    )

    # Horizontal grid

    for i in range(1, 5):

        y = int(

            top +

            i * (bottom - top) / 5

        )

        cv2.line(

            image,

            (left, y),

            (right, y),

            PLOT_CONFIG["grid_colour"],

            1

        )

    # Vertical grid

    for i in range(1, 10):

        x = int(

            left +

            i * (right - left) / 10

        )

        cv2.line(

            image,

            (x, top),

            (x, bottom),

            PLOT_CONFIG["grid_colour"],

            1

        )


# -----------------------------------------------------------------------------
# Scale Data
# -----------------------------------------------------------------------------

def scale_plot_data(data, width, height):

    """
    Converts numeric values into plotting coordinates.
    """

    if len(data) < 2:

        return []

    left = PLOT_CONFIG["margin_left"]

    right = width - PLOT_CONFIG["margin_right"]

    top = PLOT_CONFIG["margin_top"]

    bottom = height - PLOT_CONFIG["margin_bottom"]

    values = np.asarray(data, dtype=np.float32)

    minimum = np.min(values)

    maximum = np.max(values)

    if abs(maximum - minimum) < 1e-8:

        maximum = minimum + 1.0

    values = (

        values - minimum

    ) / (

        maximum - minimum

    )

    points = []

    for i, value in enumerate(values):

        x = int(

            left +

            i * (right - left) /

            (len(values) - 1)

        )

        y = int(

            bottom -

            value * (bottom - top)

        )

        points.append((x, y))

    return points


# -----------------------------------------------------------------------------
# Draw Curve
# -----------------------------------------------------------------------------

def draw_curve(image, data, colour):

    """
    Draws a line graph.
    """

    points = scale_plot_data(

        data,

        image.shape[1],

        image.shape[0]

    )

    if len(points) < 2:

        return

    for i in range(1, len(points)):

        cv2.line(

            image,

            points[i - 1],

            points[i],

            colour,

            2

        )


