@dataclass
class CalibrationResult:
    """
    Stores the completed experimental calibration.

    This object is passed to the ProcessingEngine.

    Contains:
        - Optimised grayscale weights
        - Reference sigma
        - Calibration intensities
        - User selections
        - Timestamp
    """


    weights: Optional[Tuple[float, float, float]] = None


