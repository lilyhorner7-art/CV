from PyQt5.QtWidgets import QMainWindow, QWidget, QVBoxLayout, QPushButton, QLabel
from PyQt5.QtCore import Qt
from PyQt5.QtGui import QImage, QPixmap
import cv2


class MainWindow(QMainWindow):
    """
    Main application window for the CV Mixer Project.
    Hosts the video display, dashboard, and control buttons.
    """

    def __init__(self, video_source, processing_engine, video_thread, dashboard):
        super().__init__()

        # Store references to core components
        self.video_source = video_source
        self.processing_engine = processing_engine
        self.video_thread = video_thread
        self.dashboard = dashboard

        # -------------------------------
        # Central widget & layout
        # -------------------------------
        central_widget = QWidget(self)
        self.setCentralWidget(central_widget)

        layout = QVBoxLayout()
        central_widget.setLayout(layout)

        # -------------------------------
        # Video display label
        # -------------------------------
        self.video_label = QLabel(self)
        self.video_label.setObjectName("video_label")
        self.video_label.setScaledContents(True)
        layout.addWidget(self.video_label)

        # -------------------------------
        # Control buttons
        # -------------------------------
        self.start_button = QPushButton("Start Processing", self)
        self.start_button.setObjectName("start_button")
        layout.addWidget(self.start_button)

        self.pause_button = QPushButton("Pause Processing", self)
        self.pause_button.setObjectName("pause_button")
        layout.addWidget(self.pause_button)

        self.stop_button = QPushButton("Stop Processing", self)
        self.stop_button.setObjectName("stop_button")
        layout.addWidget(self.stop_button)

        self.export_button = QPushButton("Export Results", self)
        self.export_button.setObjectName("export_button")
        layout.addWidget(self.export_button)

        # -------------------------------
        # Dashboard widget (if provided)
        # -------------------------------
        if self.dashboard is not None:
            layout.addWidget(self.dashboard)

        # -------------------------------
        # Connect signals
        # -------------------------------
        self.connect_signals()

        # -------------------------------
        # Window settings
        # -------------------------------
        self.setWindowTitle("CV Mixer Project - Main Window")
        self.resize(1200, 800)
        self.setAttribute(Qt.WA_DeleteOnClose)

    # -------------------------------------------------------------------------
    # Signal connections
    # -------------------------------------------------------------------------
    def connect_signals(self):
        """Connects UI signals to their respective slots."""
        self.start_button.clicked.connect(self.start_processing)
        self.pause_button.clicked.connect(self.pause_processing)
        self.stop_button.clicked.connect(self.stop_processing)
        self.export_button.clicked.connect(self.export_results)

        # Video thread signals
        self.video_thread.frame_processed.connect(self.update_display)
        self.video_thread.video_finished.connect(self.on_video_finished)


    # -------------------------------------------------------------------------
    # Slots
    # -------------------------------------------------------------------------
    def start_processing(self):
        if self.video_thread and not self.video_thread.isRunning():
            self.video_thread.start()
        elif self.video_thread and self.video_thread.isRunning():
            self.video_thread.resume()


    def pause_processing(self):
        if self.video_thread:
            self.video_thread.pause()


    def stop_processing(self):
        """Stop video processing."""
        if self.video_thread:
            self.video_thread.stop()

    def export_results(self):
        """Export results from the processing engine."""
        if hasattr(self.processing_engine, "export_results"):
            self.processing_engine.export_results()

    def update_display(self, frame, timestamp, frame_number):
        """
        Update the UI with the processed frame.
        """
        # Convert BGR (OpenCV) to RGB (Qt)
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb_frame.shape
        bytes_per_line = ch * w
        qimg = QImage(rgb_frame.data, w, h, bytes_per_line, QImage.Format_RGB888)

        # Show in QLabel
        self.video_label.setPixmap(QPixmap.fromImage(qimg))

        # Update status bar
        self.statusBar().showMessage(f"Frame {frame_number} @ {timestamp:.2f}s")

    def on_video_finished(self):
        """Handle end of video."""
        self.statusBar().showMessage("Video finished.")





