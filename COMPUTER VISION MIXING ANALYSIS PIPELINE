# =============================================================================
# SECTION 6.3B
# BUBBLE TRACKER CORE
# =============================================================================
#
# Responsibilities
# ---------------
#
# • Maintain persistent bubble identities
# • Match detections between frames
# • Create new tracks
# • Update existing tracks
#
# This module does NOT perform detection.
#
# =============================================================================


class BubbleTracker:
    """
    Persistent bubble tracking engine.

    Uses centroid-based nearest-neighbour matching.

    Input
    -----

    BubbleDetection objects


    Output
    ------

    TrackedBubbleResults

    """

    # =========================================================================
    # Constructor
    # =========================================================================

    def __init__(
        self,
        config: TrackerConfig
    ):

        self.config = config


        # Active bubble tracks

        self.tracks = {}


        # Unique ID counter

        self.next_track_id = 1



    # =========================================================================
    # Distance Metrics
    # =========================================================================

    @staticmethod
    def centroid_distance(
        point_a,
        point_b
    ):
        """
        Euclidean distance between two centroids.

        Returns
        -------
        float
            Pixel distance
        """

        return float(

            np.linalg.norm(

                np.array(point_a)

                -

                np.array(point_b)

            )

        )


    # -------------------------------------------------------------------------

    @staticmethod
    def area_difference(
        area_a,
        area_b
    ):
        """
        Relative area difference.

        Used as an additional matching constraint.
        """

        if area_a == 0 or area_b == 0:

            return 1.0


        return abs(

            area_a - area_b

        ) / max(

            area_a,

            area_b

        )



    # =========================================================================
    # Detection Matching
    # =========================================================================

    def nearest_neighbour_match(
        self,
        detections
    ):
        """
        Matches detections to existing tracks.

        Returns
        -------

        matches

            List of

            (
                detection_index,
                track_id
            )

        unmatched_detections

        unmatched_tracks

        """

        matches = []


        unmatched_detections = list(

            range(

                len(detections)

            )

        )


        unmatched_tracks = list(

            self.tracks.keys()

        )


        if len(self.tracks) == 0:

            return (

                matches,

                unmatched_detections,

                unmatched_tracks

            )



        # -------------------------------------------------------------
        # Build candidate distances
        # -------------------------------------------------------------

        candidates = []


        for detection_index, detection in enumerate(detections):


            for track_id, track in self.tracks.items():


                distance = self.centroid_distance(

                    detection.centroid,

                    track.centroid

                )


                area_difference = self.area_difference(

                    detection.area,

                    track.area

                )


                candidates.append(

                    (

                        distance,

                        area_difference,

                        detection_index,

                        track_id

                    )

                )



        # -------------------------------------------------------------
        # Sort closest matches first
        # -------------------------------------------------------------

        candidates.sort(

            key=lambda x: x[0]

        )



        used_detections = set()

        used_tracks = set()



        for (
            distance,
            area_difference,
            detection_index,
            track_id

        ) in candidates:



            if detection_index in used_detections:

                continue


            if track_id in used_tracks:

                continue



            if distance > self.config.max_match_distance:

                continue



            matches.append(

                (

                    detection_index,

                    track_id

                )

            )


            used_detections.add(

                detection_index

            )


            used_tracks.add(

                track_id

            )



        unmatched_detections = [

            i

            for i in range(len(detections))

            if i not in used_detections

        ]



        unmatched_tracks = [

            track_id

            for track_id in self.tracks.keys()

            if track_id not in used_tracks

        ]



        return (

            matches,

            unmatched_detections,

            unmatched_tracks

        )



    # =========================================================================
    # Track Creation
    # =========================================================================

    def create_track(
        self,
        detection,
        timestamp
    ):
        """
        Creates a new bubble track.
        """

        track_id = self.next_track_id


        self.next_track_id += 1



        track = BubbleTrack(

            track_id=track_id,

            centroid=detection.centroid,

            area=detection.area,

            equivalent_diameter=detection.equivalent_diameter,


            centroid_history=[

                detection.centroid

            ],


            area_history=[

                detection.area

            ],


            timestamp_history=[

                timestamp

            ],


            confidence_history=[

                detection.confidence

            ]

        )


        self.tracks[track_id] = track



        return track_id



    # =========================================================================
    # Update Existing Track
    # =========================================================================

    def update_track(
        self,
        track,
        detection,
        timestamp
    ):
        """
        Updates an existing track with a new detection.
        """


        previous_centroid = track.centroid



        velocity = self.centroid_distance(

            previous_centroid,

            detection.centroid

        )


        if self.config.calculate_velocity:

            if self.config.pixel_to_micron:

                velocity *= (

                    self.config.pixel_to_micron

                )



        track.add_measurement(

            centroid=detection.centroid,

            area=detection.area,

            diameter=detection.equivalent_diameter,

            timestamp=timestamp,

            velocity=velocity,

            confidence=detection.confidence,

            history_length=self.config.history_length

        )



        return velocity
    
# =============================================================================
# SECTION 6.3C
# TRACK MANAGEMENT
# =============================================================================
# Responsibilities
# ---------------
# • Maintain trajectory history
# • Calculate bubble velocity
# • Age active tracks
#• Handle missing detections
# • Remove expired tracks
# =============================================================================

# =============================================================================
# Trajectory History Management
# =============================================================================


def update_track_history(
    self,
    track,
    centroid,
    area,
    timestamp
):
    """
    Updates the trajectory history of a bubble.

    Parameters
    ----------
    track : BubbleTrack

    centroid : tuple
        Current bubble centroid.

    area : float
        Bubble area.

    timestamp : float
        Video timestamp.

    """

    track.centroid_history.append(
        centroid
    )

    track.area_history.append(
        area
    )

    track.timestamp_history.append(
        timestamp
    )


    # Maintain fixed history size

    max_length = self.config.history_length


    if len(track.centroid_history) > max_length:

        track.centroid_history.pop(0)


    if len(track.area_history) > max_length:

        track.area_history.pop(0)


    if len(track.timestamp_history) > max_length:

        track.timestamp_history.pop(0)



# =============================================================================
# Velocity Calculation
# =============================================================================


def calculate_velocity(
    self,
    previous_centroid,
    current_centroid,
    previous_time,
    current_time
):
    """
    Calculates bubble velocity.

    Velocity is calculated using:

        velocity = displacement / time


    Returns
    -------
    float

        pixels/sec

    """


    displacement = self.centroid_distance(
        previous_centroid,
        current_centroid
    )


    delta_time = (
        current_time -
        previous_time
    )


    if delta_time <= 0:

        return 0.0


    velocity = (
        displacement /
        delta_time
    )


    # Convert pixels to microns if calibrated

    if self.config.pixel_to_micron:

        velocity *= (
            self.config.pixel_to_micron
        )


    return float(
        velocity
    )



# =============================================================================
# Velocity Smoothing
# =============================================================================


def smooth_velocity(
    self,
    track
):
    """
    Applies moving average smoothing to velocity.

    Reduces frame-to-frame noise.
    """


    window = self.config.velocity_smoothing


    if len(track.velocity_history) < window:

        return track.velocity


    recent = track.velocity_history[-window:]


    return float(
        np.mean(recent)
    )



# =============================================================================
# Track Ageing
# =============================================================================


def age_track(
    self,
    track
):
    """
    Increases track age.

    Called every time a bubble
    is successfully detected.
    """


    track.age += 1

    track.missing_frames = 0


    track.status = (
        TrackStatus.ACTIVE
    )



# =============================================================================
# Missing Frame Handling
# =============================================================================


def mark_track_missing(
    self,
    track
):
    """
    Handles a bubble that was not
    detected in the current frame.

    The track is kept temporarily
    in case the bubble reappears.
    """


    track.missing_frames += 1



    if (
        track.missing_frames
        <
        self.config.max_missing_frames
    ):

        track.status = (
            TrackStatus.LOST
        )


    else:

        track.status = (
            TrackStatus.TERMINATED
        )



# =============================================================================
# Remove Expired Tracks
# =============================================================================


def remove_expired_tracks(
    self
):
    """
    Deletes tracks that have exceeded
    the maximum allowed missing frames.

    Returns
    -------

    list

        Removed track IDs

    """


    removed = []


    expired = []


    for track_id, track in self.tracks.items():


        if track.status == TrackStatus.TERMINATED:

            expired.append(
                track_id
            )


    for track_id in expired:


        removed.append(
            track_id
        )


        del self.tracks[
            track_id
        ]


    return removed



# =============================================================================
# Track Statistics
# =============================================================================


def calculate_track_statistics(
    self
):
    """
    Calculates current tracker statistics.

    Used by:
    - PyQt5 dashboard
    - Excel export
    - Scientific analysis

    """

    active_tracks = [

        track

        for track in self.tracks.values()

        if track.status != TrackStatus.TERMINATED

    ]


    if len(active_tracks) == 0:

        return {

            "active_tracks": 0,

            "mean_velocity": 0,

            "mean_area": 0,

            "mean_age": 0

        }


    return {


        "active_tracks":
            len(active_tracks),


        "mean_velocity":
            float(
                np.mean(
                    [
                        t.velocity
                        for t in active_tracks
                    ]
                )
            ),


        "mean_area":
            float(
                np.mean(
                    [
                        t.area
                        for t in active_tracks
                    ]
                )
            ),


        "mean_age":
            float(
                np.mean(
                    [
                        t.age
                        for t in active_tracks
                    ]
                )
            )

    }

# =============================================================================
# SECTION 6.3D
# COMPLETE BUBBLE TRACKER UPDATE PIPELINE
# =============================================================================
# Responsibilities
# ---------------
# • Accept BubbleDetectionResults
# • Match detections to existing tracks
# • Update matched tracks
# • Create new tracks
# • Handle missing tracks
# • Remove expired tracks
# • Calculate tracking statistics
# • Return TrackedBubbleResults
# =============================================================================

# =============================================================================
# Complete Tracker Update Pipeline
# =============================================================================


def update(
    self,
    detection_results,
    timestamp
):
    """
    Main bubble tracking update function.

    Parameters
    ----------
    detection_results :
        BubbleDetectionResults object

    timestamp : float
        Current video timestamp (seconds)


    Returns
    -------
    TrackedBubbleResults

    """


    detections = (
        detection_results.detections
    )


    # -------------------------------------------------------------------------
    # Store tracking events
    # -------------------------------------------------------------------------

    matched_tracks = []

    new_tracks = []



    removed_tracks = []



    # -------------------------------------------------------------------------
    # Match detections to existing tracks
    # -------------------------------------------------------------------------

    (
        matches,

        unmatched_detections,

        unmatched_tracks

    ) = self.nearest_neighbour_match(
        detections
    )



    # -------------------------------------------------------------------------
    # Update existing tracks
    # -------------------------------------------------------------------------

    for (
        detection_index,
        track_id

    ) in matches:


        detection = detections[
            detection_index
        ]


        track = self.tracks[
            track_id
        ]


        velocity = self.calculate_velocity(

            track.centroid,

            detection.centroid,

            track.timestamp_history[-1],

            timestamp

        )


        self.update_track(

            track,

            detection,

            timestamp

        )


        track.velocity = velocity


        track.velocity_history.append(
            velocity
        )


        # Smooth velocity

        if self.config.velocity_smoothing > 1:

            track.velocity = self.smooth_velocity(
                track
            )



        self.age_track(
            track
        )


        matched_tracks.append(
            track_id
        )



    # -------------------------------------------------------------------------
    # Create new tracks
    # -------------------------------------------------------------------------

    for detection_index in unmatched_detections:


        detection = detections[
            detection_index
        ]


        track_id = self.create_track(

            detection,

            timestamp

        )


        new_tracks.append(
            track_id
        )



    # -------------------------------------------------------------------------
    # Handle missing tracks
    # -------------------------------------------------------------------------

    for track_id in unmatched_tracks:


        track = self.tracks[
            track_id
        ]


        self.mark_track_missing(
            track
        )



    # -------------------------------------------------------------------------
    # Remove expired tracks
    # -------------------------------------------------------------------------

    removed_tracks = (

        self.remove_expired_tracks()

    )



    # -------------------------------------------------------------------------
    # Calculate statistics
    # -------------------------------------------------------------------------

    statistics = (

        self.calculate_track_statistics()

    )



    # -------------------------------------------------------------------------
    # Return tracking result
    # -------------------------------------------------------------------------

    return TrackedBubbleResults(

        timestamp=timestamp,

        active_tracks=self.tracks.copy(),

        new_tracks=new_tracks,

        removed_tracks=removed_tracks,

        matched_tracks=matched_tracks,

        statistics=statistics

    )

