@dataclass
class BaselineResult:
    """
    Result returned by the baseline capture stage.

    Attributes
    ----------
    captured : bool
        True once the experimental baseline has been established.

    sigma_reference : float | None
        Reference sigma used for all RMI calculations.

    interface_roi : ndarray | None
        Baseline interface ROI (grayscale).

    frames_used : int
        Number of frames averaged.

    method : str
        Baseline estimation method.
    """

    captured: bool
    sigma_reference: Optional[float]
    interface_roi: Optional[np.ndarray]
    frames_used: int
    method: str


# -----------------------------------------------------------------------------
# Baseline Buffer
# -----------------------------------------------------------------------------

BASELINE_BUFFER = deque(maxlen=BASELINE_CAPTURE_FRAME)


# -----------------------------------------------------------------------------
# Reset Baseline
# -----------------------------------------------------------------------------

def reset_baseline():
    """
    Clears every stored baseline measurement.

    Call this whenever:
        • a new video is opened
        • calibration is repeated
        • ROIs are changed
    """

    BASELINE_BUFFER.clear()

    STATE["baseline_sigma"] = None
    STATE["baseline_roi"] = None

    
# -----------------------------------------------------------------------------
# Compute Interface Sigma
# -----------------------------------------------------------------------------

def compute_interface_sigma(interface_roi):
    """
    Computes sigma from the interface ROI.

    Returns
    -------
    float
    """

    return compute_sigma(
        interface_roi,
        PROFILE_AXES["Interface"]
    )


# -----------------------------------------------------------------------------
# Baseline Already Captured?
# -----------------------------------------------------------------------------

def baseline_available():
    """
    Returns
    -------
    bool
    """

    return STATE["baseline_sigma"] is not None


# -----------------------------------------------------------------------------
# Update Baseline Buffer
# -----------------------------------------------------------------------------

def update_baseline_buffer(interface_roi):
    """
    Adds the latest interface sigma measurement to the rolling buffer.
    """

    sigma = compute_interface_sigma(interface_roi)

    BASELINE_BUFFER.append(sigma)


# -----------------------------------------------------------------------------
# Compute Stable Baseline
# -----------------------------------------------------------------------------

def compute_baseline_from_buffer():
    """
    Computes the reference sigma from the rolling baseline buffer.

    Version 6 improvement:
        Uses the mean of multiple frames rather than
        a single snapshot.

    Returns
    -------
    float
    """

    values = np.asarray(BASELINE_BUFFER, dtype=np.float32)

    return float(np.mean(values))


# -----------------------------------------------------------------------------
# Capture Baseline
# -----------------------------------------------------------------------------

def capture_baseline(preprocessed):
    """
    Captures the experimental baseline automatically.

    Workflow
    --------
    1. Extract interface ROI
    2. Compute interface sigma
    3. Build rolling buffer
    4. Wait until enough frames collected
    5. Compute average sigma
    6. Store reference

    Parameters
    ----------
    preprocessed : FramePreprocessingResult

    Returns
    -------
    BaselineResult
    """

    # ---------------------------------------------------------
    # Already available
    # ---------------------------------------------------------

    if baseline_available():

        return BaselineResult(

            captured=True,

            sigma_reference=STATE["baseline_sigma"],

            interface_roi=STATE["baseline_roi"],

            frames_used=len(BASELINE_BUFFER),

            method="Rolling Average"

        )

    # ---------------------------------------------------------
    # Current interface ROI
    # ---------------------------------------------------------

    interface_roi = preprocessed.roi_gray["Interface"]

    update_baseline_buffer(interface_roi)

    # ---------------------------------------------------------
    # Still collecting
    # ---------------------------------------------------------

    if len(BASELINE_BUFFER) < BASELINE_CAPTURE_FRAME:

        return BaselineResult(

            captured=False,

            sigma_reference=None,

            interface_roi=None,

            frames_used=len(BASELINE_BUFFER),

            method="Collecting"

        )

    # ---------------------------------------------------------
    # Compute reference sigma
    # ---------------------------------------------------------

    sigma_reference = compute_baseline_from_buffer()

    STATE["baseline_sigma"] = sigma_reference

    STATE["baseline_roi"] = interface_roi.copy()

    print(
        f"\nBaseline captured "
        f"({len(BASELINE_BUFFER)} frames)"
    )

    print(
        f"Reference σ = "
        f"{sigma_reference:.4f}"
    )

    return BaselineResult(

        captured=True,

        sigma_reference=sigma_reference,

        interface_roi=STATE["baseline_roi"],

        frames_used=len(BASELINE_BUFFER),

        method="Rolling Average"

    )

