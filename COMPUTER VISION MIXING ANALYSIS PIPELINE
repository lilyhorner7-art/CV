        Connects the VideoThread to the GUI.
        """


        self.video_thread.frame_ready.connect(
            self.update_frame
        )



    # -------------------------------------------------------------------------
    # Frame Update
    # -------------------------------------------------------------------------

    def update_frame(
        self,
        frame,
        timestamp,
        frame_number
    ):
        """
        Receives frames from VideoThread.
        """


        self.current_frame = frame.copy()


        self.display_frame = (
            self.draw_overlay(
                frame.copy()
            )
        )


        self.display_image(
            self.display_frame
        )



    # -------------------------------------------------------------------------
    # Mouse Selection
    # -------------------------------------------------------------------------

    def video_clicked(
        self,
        event
    ):
        """
        Records calibration point selection.

        Uses display coordinates and converts them
        back to original image coordinates.
        """


        if self.current_frame is None:

            return



        if self.current_selection >= len(
            self.point_labels
        ):

            return



        x = event.position().x()

        y = event.position().y()



        image_x, image_y = (
            self.convert_display_to_image(
                x,
                y
            )
        )



        point = CalibrationPoint(

            name=
            self.point_labels[
                self.current_selection
            ],

            x=image_x,

            y=image_y,

            patch_size=self.patch_size

        )



        self.calibration_points.append(
            point
        )



        self.current_selection += 1


        self.update_instructions()



    # -------------------------------------------------------------------------
    # Coordinate Conversion
    # -------------------------------------------------------------------------

    def convert_display_to_image(
        self,
        x,
        y
    ):
        """
        Converts QLabel coordinates into
        original frame coordinates.
        """


        label_width = (
            self.video_label.width()
        )


        label_height = (
            self.video_label.height()
        )


        frame_height, frame_width = (
            self.current_frame.shape[:2]
        )


        scale_x = (
            frame_width /
            label_width
        )


        scale_y = (
            frame_height /
            label_height
        )


        return (

            int(x * scale_x),

            int(y * scale_y)

        )



    # -------------------------------------------------------------------------
    # Drawing
    # -------------------------------------------------------------------------

    def draw_overlay(
        self,
        frame
    ):
        """
        Draws calibration markers.
        """


        for point in self.calibration_points:


            cv2.rectangle(

                frame,

                (
                    point.x -
                    self.patch_size//2,

                    point.y -
                    self.patch_size//2
                ),

                (
                    point.x +
                    self.patch_size//2,

                    point.y +
                    self.patch_size//2
                ),

                (0,255,0),

                2

            )


            cv2.circle(

                frame,

                (
                    point.x,
                    point.y
                ),

                5,

                (0,0,255),

                -1

            )


        return frame



    # -------------------------------------------------------------------------
    # Display Conversion
    # -------------------------------------------------------------------------

    def display_image(
        self,
        frame
    ):
        """
        Converts OpenCV image to Qt image.
        """


        rgb = cv2.cvtColor(
            frame,
            cv2.COLOR_BGR2RGB
        )


        h,w,ch = rgb.shape


        qt_image = QImage(

            rgb.data,

            w,

            h,

            rgb.strides[0],

            QImage.Format_RGB888

        )


        self.video_label.setPixmap(

            QPixmap.fromImage(
                qt_image
            ).scaled(

                self.video_label.size(),

                Qt.KeepAspectRatio

            )

        )



    # -------------------------------------------------------------------------
    # Instructions
    # -------------------------------------------------------------------------

    def update_instructions(self):

        text = (

            "CALIBRATION\n\n"

        )


        for i,label in enumerate(
            self.point_labels
        ):


            if i < len(
                self.calibration_points
            ):

                status = "✓"

            elif i == self.current_selection:

                status = "← Select"

            else:

                status = ""


            text += (

                f"{i+1}. {label} {status}\n"

            )



        text += (

            "\nClick the required fluid regions."

            "\n\nReset clears selections."

        )


        self.instruction_box.setText(
            text
        )



    # -------------------------------------------------------------------------
    # Reset
    # -------------------------------------------------------------------------

    def reset_selection(self):

        self.calibration_points.clear()


        self.current_selection = 0


        self.update_instructions()



    # -------------------------------------------------------------------------
    # Confirm
    # -------------------------------------------------------------------------

    def confirm_calibration(self):

        if len(
            self.calibration_points
        ) < 2:


            QMessageBox.warning(

                self,

                "Calibration",

                "Please select calibration points first."

            )

            return



        for point in self.calibration_points:

            self.state.calibration.calibration_points[
                point.name
            ] = point



        self.calibration_complete.emit(
            self.state
        )


        self.close()



    # -------------------------------------------------------------------------
    # Cancel
    # -------------------------------------------------------------------------

    def cancel(self):

        self.calibration_cancelled.emit()

        self.close()

