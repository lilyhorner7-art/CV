    """
    Complete Version 6 bubble processing pipeline.

    Workflow
    --------
    1. Bubble detection
    2. Bubble tracking
    3. Manual validation
    4. Bubble statistics
    5. Update runtime state
    6. Package results

    Parameters
    ----------
    preprocessed : FramePreprocessingResult

    Returns
    -------
    BubbleProcessingResult
    """

    # ---------------------------------------------------------
    # Detection
    # ---------------------------------------------------------

    detection_results = perform_detection(
        preprocessed
    )

    # ---------------------------------------------------------
    # Tracking
    # ---------------------------------------------------------

    tracking_results = perform_tracking(
        detection_results
    )

    # ---------------------------------------------------------
    # Validation
    # ---------------------------------------------------------

    validation_results = perform_validation(
        tracking_results
    )

    # ---------------------------------------------------------
    # Analysis
    # ---------------------------------------------------------

    analysis_results = perform_analysis(
        validation_results
    )

    # ---------------------------------------------------------
