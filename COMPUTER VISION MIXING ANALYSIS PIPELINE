# -----------------------------------------------------------------------------
# RMIComputationResult
# -----------------------------------------------------------------------------

@dataclass
class RMIComputationResult:
    """
    Stores all Relative Mixing Index calculations for a frame.

    Attributes
    ----------
    rmi : dict
        RMI value for each analysis ROI.

    sigma : dict
        Sigma value for each analysis ROI.

    line_profiles : dict
        One-dimensional intensity profiles used for sigma calculation.

    baseline_sigma : float

    valid : bool
        False if the baseline has not yet been captured.
    """

    rmi: Dict[str, float] = field(default_factory=dict)

    sigma: Dict[str, float] = field(default_factory=dict)

    line_profiles: Dict[str, np.ndarray] = field(default_factory=dict)

    baseline_sigma: float = 0.0

    valid: bool = False


# -----------------------------------------------------------------------------
# Compute ROI Line Profile
# -----------------------------------------------------------------------------

def compute_roi_profile(
    roi_name,
    gray_roi
):
    """
    Computes the 1D intensity profile for an ROI.

    Parameters
    ----------
    roi_name : str

    gray_roi : ndarray

    Returns
    -------
    ndarray
    """

    axis = PROFILE_AXES[roi_name]

    return compute_line_profile(
        gray_roi,
        axis
    )


# -----------------------------------------------------------------------------
# Compute Single ROI RMI
# -----------------------------------------------------------------------------

def compute_single_roi_rmi(
    roi_name,
    gray_roi,
    sigma_reference
):
    """
    Computes the RMI and sigma for one ROI.

    Returns
    -------
    tuple

        (profile,
         sigma,
         rmi)
    """

    profile = compute_roi_profile(
        roi_name,
        gray_roi
    )

    sigma = float(np.std(profile))

    if sigma_reference <= 0:

        rmi = 0.0

    else:

        rmi = float(

            np.clip(

                1.0 - sigma / sigma_reference,

                0.0,

                1.0

            )

        )

    return profile, sigma, rmi


# -----------------------------------------------------------------------------
# Initialise Empty Result
# -----------------------------------------------------------------------------

def empty_rmi_result():
    """
    Returns an empty RMI result before baseline capture.
    """

    result = RMIComputationResult()

    for roi_name in PROFILE_AXES:

        result.rmi[roi_name] = 0.0

        result.sigma[roi_name] = 0.0

        result.line_profiles[roi_name] = np.array([])

    result.valid = False

    return result


# -----------------------------------------------------------------------------
# Complete RMI Calculation
# -----------------------------------------------------------------------------

def compute_rmi_results(
    preprocessed,
    baseline_result
):
    """
    Computes the Relative Mixing Index for every analysis ROI.

    Workflow
    --------
    1. Check baseline availability
    2. Compute line profile
    3. Compute sigma
    4. Compute RMI
    5. Store results
    6. Update STATE

    Parameters
    ----------
    preprocessed : FramePreprocessingResult

    baseline_result : BaselineResult

    Returns
    -------
    RMIComputationResult
    """

    # ---------------------------------------------------------
    # Baseline not yet available
    # ---------------------------------------------------------

    if not baseline_result.captured:

        return empty_rmi_result()

    # ---------------------------------------------------------
    # Create result object
    # ---------------------------------------------------------

    result = RMIComputationResult()

    result.valid = True

    result.baseline_sigma = baseline_result.sigma_reference

    # ---------------------------------------------------------
    # Compute every ROI
    # ---------------------------------------------------------

    for roi_name in PROFILE_AXES:

        gray_roi = preprocessed.roi_gray[roi_name]

        profile, sigma, rmi = compute_single_roi_rmi(

            roi_name,

            gray_roi,

            baseline_result.sigma_reference

        )

        result.line_profiles[roi_name] = profile

        result.sigma[roi_name] = sigma

        result.rmi[roi_name] = rmi

    # ---------------------------------------------------------
    # Update runtime state
    # ---------------------------------------------------------

    STATE["rmi"] = result.rmi.copy()

    STATE["sigma"] = result.sigma.copy()

    # ---------------------------------------------------------
    # Update time histories
    # ---------------------------------------------------------

    for roi_name in PROFILE_AXES:

        STATE["rmi_history"][roi_name].append(
            result.rmi[roi_name]
        )

        STATE["sigma_history"][roi_name].append(
            result.sigma[roi_name]
        )

    # ---------------------------------------------------------
    # Return results
    # ---------------------------------------------------------

    return result

