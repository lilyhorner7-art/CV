class OverlayRenderer:
    """
    Draws all overlays used by the bubble tracking system.

    The renderer only visualises data.
    It never performs image processing.
    """

    # -------------------------------------------------------------------------
    # Draw tracked bubbles
    # -------------------------------------------------------------------------

    def draw_bubbles(
        self,
        frame,
        tracking_results
    ):
        """
        Draw tracked bubbles onto the outlet image.
        """

        if tracking_results is None:
            return

        for track in tracking_results.active_tracks.values():

            x, y = map(int, track.centroid)

            # Bubble centre
            cv2.circle(
                frame,
                (x, y),
                5,
                (0, 255, 0),
                -1
            )

            # Bubble ID
            cv2.putText(
                frame,
                f"ID {track.track_id}",
                (x + 8, y - 8),
                cv2.FONT_HERSHEY_SIMPLEX,
                0.5,
                (0, 255, 0),
                1,
                cv2.LINE_AA
            )

    # -------------------------------------------------------------------------
    # Draw trajectories
    # -------------------------------------------------------------------------

    def draw_tracking_overlay(
        self,
        frame,
        tracking_results
    ):
        """
        Draw bubble trajectories.
        """

        if tracking_results is None:
            return

        for track in tracking_results.active_tracks.values():

            history = track.centroid_history

            if len(history) < 2:
                continue

            for i in range(1, len(history)):

                cv2.line(
                    frame,
                    tuple(map(int, history[i - 1])),
                    tuple(map(int, history[i])),
                    (255, 0, 0),
                    2
                )

    # -------------------------------------------------------------------------
    # Draw ROIs
    # -------------------------------------------------------------------------

    def draw_rois(
        self,
        frame,
        roi_points
    ):
        """
        Draw all configured ROIs.
        """

        if roi_points is None:
            return

        for roi_name, roi in roi_points.items():

            x1, y1, x2, y2 = roi

            cv2.rectangle(
                frame,
                (x1, y1),
                (x2, y2),
                (0, 255, 255),
                2
            )

            cv2.putText(
                frame,
                roi_name,
                (x1, y1 - 5),
                cv2.FONT_HERSHEY_SIMPLEX,
                0.5,
                (0, 255, 255),
                1,
                cv2.LINE_AA
            )

    # -------------------------------------------------------------------------
    # Draw RMI
    # -------------------------------------------------------------------------

    def draw_rmi_results(
        self,
        frame,
        rmi
    ):
        """
        Draw current RMI value.
        """

        if rmi is None:
            return

        cv2.putText(
            frame,
            f"RMI : {rmi:.3f}",
            (20, 35),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.8,
            (255, 255, 255),
            2,
            cv2.LINE_AA
        )

    # -------------------------------------------------------------------------
    # Draw statistics
    # -------------------------------------------------------------------------

    def draw_processing_statistics(
        self,
        frame,
        tracking_results
    ):
        """
        Draw processing statistics.
        """

        if tracking_results is None:
            return

        number_of_tracks = len(
            tracking_results.active_tracks
        )

        cv2.putText(
            frame,
            f"Active Tracks : {number_of_tracks}",
            (20, 70),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.6,
            (255, 255, 255),
            2,
            cv2.LINE_AA
        )


