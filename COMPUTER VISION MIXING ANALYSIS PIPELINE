@dataclass
class BubbleTrack:
    """
    Persistent representation of a bubble.

    A BubbleTrack represents one physical bubble followed
    through multiple frames.
    """

    # -------------------------------------------------------------------------
    # Identity
    # -------------------------------------------------------------------------

    track_id: int


    # -------------------------------------------------------------------------
    # Current measurements
    # -------------------------------------------------------------------------

    centroid: Tuple[int, int]

    area: float

    equivalent_diameter: float


    # -------------------------------------------------------------------------
    # Tracking history
    # -------------------------------------------------------------------------

    centroid_history: List[
        Tuple[int, int]
    ] = field(default_factory=list)


    area_history: List[
        float
    ] = field(default_factory=list)


    timestamp_history: List[
        float
    ] = field(default_factory=list)



    # -------------------------------------------------------------------------
    # Motion information
    # -------------------------------------------------------------------------

    velocity: float = 0.0

    velocity_history: List[
        float
    ] = field(default_factory=list)



    # -------------------------------------------------------------------------
    # Lifecycle
    # -------------------------------------------------------------------------

    age: int = 1

    missing_frames: int = 0

    status: TrackStatus = (
        TrackStatus.ACTIVE
    )


    # -------------------------------------------------------------------------
    # Validation
    # -------------------------------------------------------------------------

    validated: bool = False

    validation_count: int = 0



    # -------------------------------------------------------------------------
    # Detection quality
    # -------------------------------------------------------------------------

    confidence_history: List[
        float
    ] = field(default_factory=list)



    # =========================================================================
    # Update Track History
    # =========================================================================

    def add_measurement(
        self,
        centroid,
        area,
        diameter,
        timestamp,
        velocity,
        confidence,
        history_length
    ):
        """
        Adds a new observation to the track.
        """

        self.centroid = centroid

        self.area = area

        self.equivalent_diameter = diameter


        self.centroid_history.append(
            centroid
        )

        self.area_history.append(
            area
        )

        self.timestamp_history.append(
            timestamp
        )


        self.velocity = velocity

        self.velocity_history.append(
            velocity
        )


        self.confidence_history.append(
            confidence
        )


        self.age += 1

        self.missing_frames = 0


        if len(self.centroid_history) > history_length:

            self.centroid_history.pop(0)


        if len(self.area_history) > history_length:

            self.area_history.pop(0)


        if len(self.timestamp_history) > history_length:

            self.timestamp_history.pop(0)


        if len(self.velocity_history) > history_length:

            self.velocity_history.pop(0)


        if len(self.confidence_history) > history_length:

            self.confidence_history.pop(0)



    # =========================================================================
    # Mark Missing
    # =========================================================================

    def mark_missing(self):
        """
        Called when the bubble is not detected.
        """

        self.missing_frames += 1



