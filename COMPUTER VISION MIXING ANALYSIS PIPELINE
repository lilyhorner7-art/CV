@dataclass
class MixingRateResults:
    """
    Stores mixing-rate information for a single ROI.
    """

    roi_name: str

    time: list

    rmi: list

    rate: list

    mean_rate: float

    maximum_rate: float

    minimum_rate: float

    final_rate: float


# -----------------------------------------------------------------------------
# Numerical Derivative
# -----------------------------------------------------------------------------

def compute_mixing_rate(time_history, rmi_history):
    """
    Computes the instantaneous mixing rate (dRMI/dt).

    Parameters
    ----------
    time_history : sequence

    rmi_history : sequence

    Returns
    -------
    list
        Mixing rate at each sample.
    """

    if len(time_history) < 2:
        return [0.0] * len(time_history)

    t = np.asarray(time_history, dtype=np.float64)
    rmi = np.asarray(rmi_history, dtype=np.float64)

    rate = np.zeros_like(rmi)

    for i in range(1, len(rmi)):

        dt = t[i] - t[i - 1]

        if dt <= 0:

            rate[i] = rate[i - 1]

        else:

            rate[i] = (

                rmi[i] - rmi[i - 1]

            ) / dt

    return rate.tolist()


# -----------------------------------------------------------------------------
# ROI Mixing Analysis
# -----------------------------------------------------------------------------

def analyse_roi_mixing(roi_name):
    """
    Performs complete mixing-rate analysis for one ROI.

    Parameters
    ----------
    roi_name : str

    Returns
    -------
    MixingRateResults
    """

    time_history = STATE["t"]

    rmi_history = STATE["rmi_history"][roi_name]

    rate = compute_mixing_rate(

        time_history,

        rmi_history

    )

    if len(rate) == 0:

        return MixingRateResults(

            roi_name=roi_name,

            time=[],

            rmi=[],

            rate=[],

            mean_rate=0.0,

            maximum_rate=0.0,

            minimum_rate=0.0,

            final_rate=0.0

        )

    return MixingRateResults(

        roi_name=roi_name,

        time=list(time_history),

        rmi=list(rmi_history),

        rate=rate,

        mean_rate=float(np.mean(rate)),

        maximum_rate=float(np.max(rate)),

        minimum_rate=float(np.min(rate)),

        final_rate=float(rate[-1])

    )


# -----------------------------------------------------------------------------
# Complete Mixing Analysis
# -----------------------------------------------------------------------------

def analyse_mixing_rates():
    """
    Computes mixing-rate analysis for every RMI ROI.

    Returns
    -------
    dict
        Dictionary of MixingRateResults objects.
    """

    results = {}

    for roi_name in STATE["rmi_history"]:

        analysis = analyse_roi_mixing(

            roi_name

        )

        results[roi_name] = analysis

        STATE["mixing_rate"][roi_name] = analysis.rate

    return results


# -----------------------------------------------------------------------------
# Peak Mixing Location
# -----------------------------------------------------------------------------

def find_peak_mixing_region(mixing_results):
    """
    Determines which ROI exhibited the highest
    average mixing rate.

    Parameters
    ----------
    mixing_results : dict

    Returns
    -------
    tuple

        (roi_name, mean_rate)
    """

    if len(mixing_results) == 0:

        return None, 0.0

    best_roi = None

    best_rate = -np.inf

    for roi_name, result in mixing_results.items():

        if result.mean_rate > best_rate:

            best_rate = result.mean_rate

            best_roi = roi_name

    return best_roi, best_rate


# -----------------------------------------------------------------------------
# Mixing Analysis Summary
# -----------------------------------------------------------------------------

def summarise_mixing_analysis():
    """
    Executes the complete mixing-rate analysis.

    Returns
    -------
    dict
    """

    results = analyse_mixing_rates()

    best_roi, best_rate = find_peak_mixing_region(

        results

    )

    return {

        "mixing_results": results,

        "highest_mixing_region": best_roi,

        "highest_mean_rate": best_rate

    }

