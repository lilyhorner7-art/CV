# =============================================================================
# Calibration Patch Mean RGB
# =============================================================================

def get_patch_mean_rgb(
    image: np.ndarray,
    centre: Tuple[int, int],
    patch_size: int
) -> np.ndarray:
    """
    Computes the mean RGB value within a square calibration patch.

    Notes
    -----
    Calibration points are selected using (x, y) coordinates.

    ROI extraction throughout the remainder of the program uses
    (y1, y2, x1, x2).

    Parameters
    ----------
    image : ndarray

        Input BGR image.

    centre : tuple

        Calibration point (x, y).

    patch_size : int

        Width of the square calibration patch.

    Returns
    -------
    ndarray

        Mean RGB values

            [R, G, B]

        dtype=float32
    """

    if image is None:
        raise ValueError("Input image is None.")

    if image.size == 0:
        raise ValueError("Input image is empty.")

    x, y = map(int, centre)

    half = patch_size // 2

    x1 = max(0, x - half)
    x2 = min(image.shape[1], x + half)

    y1 = max(0, y - half)
    y2 = min(image.shape[0], y + half)

    patch = image[y1:y2, x1:x2]

    if patch.size == 0:
        raise ValueError("Calibration patch contains no pixels.")

    mean_bgr = patch.reshape(-1, 3).mean(axis=0)

    blue, green, red = mean_bgr

    return np.array(
        [red, green, blue],
        dtype=np.float32
    )


# =============================================================================
# Custom Grayscale Conversion
# =============================================================================

def grayscale_with_weights(
    image: np.ndarray,
    weights: Sequence[float]
) -> np.ndarray:
    """
    Converts a BGR image into a custom grayscale image using
    optimised RGB weighting.

    Parameters
    ----------
    image : ndarray

        Input BGR image.

    weights : sequence

        (R_weight, G_weight, B_weight)

    Returns
    -------
    ndarray

        Custom grayscale image.
    """

    if image is None:
        raise ValueError("Input image is None.")

    if image.size == 0:
        raise ValueError("Input image is empty.")

    r_weight, g_weight, b_weight = weights

    image_float = image.astype(np.float32)

    grayscale = (

        image_float[:, :, 2] * r_weight +

        image_float[:, :, 1] * g_weight +

        image_float[:, :, 0] * b_weight

    )

    grayscale = np.clip(
        grayscale,
        0,
        255
    )

    return grayscale.astype(np.uint8)


# =============================================================================
# Optional Contrast Normalisation
# =============================================================================

def normalise_grayscale(
    grayscale: np.ndarray
) -> np.ndarray:
    """
    Linearly stretches a grayscale image to the full
    intensity range [0,255].

    Notes
    -----
    This function is intended for visualisation and bubble
    detection only.

    It MUST NOT be used when computing the Relative Mixing
    Index, since altering the grayscale distribution would
    invalidate the experimental measurements.

    Parameters
    ----------
    grayscale : ndarray

        Input grayscale image.

    Returns
    -------
    ndarray

        Contrast-normalised grayscale image.
    """

    if grayscale is None:
        return np.empty((0, 0), dtype=np.uint8)

    if grayscale.size == 0:
        return grayscale

    minimum = float(np.min(grayscale))
    maximum = float(np.max(grayscale))

    if maximum <= minimum:
        return grayscale.copy()

    stretched = (

        (grayscale.astype(np.float32) - minimum)

        / (maximum - minimum)

    ) * 255.0

    return stretched.astype(np.uint8)


# =============================================================================
# Display Helper
# =============================================================================

def grayscale_to_bgr(
    grayscale: np.ndarray
) -> np.ndarray:
    """
    Converts a grayscale image into BGR format.

    Used when displaying grayscale ROIs inside the
    Version 6 dashboard.

    Parameters
    ----------
    grayscale : ndarray

        Input grayscale image.

    Returns
    -------
    ndarray

        Three-channel BGR image.
    """

    if grayscale is None:
        return np.empty((0, 0, 3), dtype=np.uint8)

    if grayscale.size == 0:
        return np.empty((0, 0, 3), dtype=np.uint8)

    return cv2.cvtColor(
        grayscale,
        cv2.COLOR_GRAY2BGR
    )


