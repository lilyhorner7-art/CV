import numpy as np
import pandas as pd
# -----------------------------------------------------------------------------
# RMI Statistics
# -----------------------------------------------------------------------------
def calculate_rmi_statistics(
    state=STATE
):
    """
    Calculates statistical properties of RMI signals.

    Metrics:
        • Mean RMI
        • Standard deviation
        • Minimum
        • Maximum
        • Range
        • Final value

    Returns
    -------
    dict
    """

    statistics = {}


    for roi_name, values in state["rmi_history"].items():


        if len(values) == 0:

            continue


        values = np.asarray(
            values,
            dtype=float
        )


        statistics[roi_name] = {


            "mean":

                np.mean(values),


            "std":

                np.std(values),


            "minimum":

                np.min(values),


            "maximum":

                np.max(values),


            "range":

                np.max(values)
                -
                np.min(values),


            "final":

                values[-1]

        }


    state["rmi_statistics"] = statistics


    return statistics
# -----------------------------------------------------------------------------
# Mixing Rate Calculation
# -----------------------------------------------------------------------------
def calculate_mixing_rate(
    state=STATE
):
    """
    Calculates the rate of RMI improvement.

    The mixing rate is calculated as:

        d(RMI) / dt

    Returns
    -------
    dict
    """

    rates = {}


    time = np.asarray(
        state["t"],
        dtype=float
    )


    if len(time) < 2:

        return rates



    for roi_name, values in state["rmi_history"].items():


        if len(values) < 2:

            continue


        values = np.asarray(
            values,
            dtype=float
        )


        dt = np.diff(time)


        drmi = np.diff(values)


        rate = (

            drmi /

            dt

        )


        rates[roi_name] = rate.tolist()



    state["mixing_rate"] = rates


    return rates
# -----------------------------------------------------------------------------
# Steady-State Detection
# -----------------------------------------------------------------------------
def detect_steady_state(
    state=STATE,
    window=STEADY_STATE_WINDOW,
    threshold=STEADY_STATE_THRESHOLD
):
    """
    Detects when mixing reaches steady state.

    Method
    ------
    Calculates rolling RMI standard deviation.

    A steady state is reached when:

        std(RMI) < threshold

    for a complete window.

    Returns
    -------
    dict
    """

    rmi = np.asarray(

        state["rmi_history"]["Interface"],

        dtype=float

    )


    if len(rmi) < window:

        return state["steady_state"]



    for i in range(

        window,

        len(rmi)

    ):


        segment = rmi[

            i-window:i

        ]


        deviation = np.std(
            segment
        )


        if deviation < threshold:


            state["steady_state"] = {


                "detected":

                    True,


                "frame":

                    i,


                "time":

                    state["t"][i],


                "sigma":

                    deviation

            }


            return state["steady_state"]



    return state["steady_state"]
# -----------------------------------------------------------------------------
# Bubble Statistics
# -----------------------------------------------------------------------------
def calculate_bubble_statistics(
    state=STATE
):
    """
    Calculates bubble population statistics.

    Metrics:
        • Mean bubble count
        • Maximum bubble count
        • Mean velocity
        • Mean lifetime
        • Maximum lifetime

    Returns
    -------
    dict
    """

    statistics = {}


    counts = np.asarray(

        state["bubble_history"],

        dtype=float

    )


    if len(counts):

        statistics["mean_count"] = (
            np.mean(counts)
        )

        statistics["maximum_count"] = (
            np.max(counts)
        )



    ages = []


    velocities = []


    for track in STATE["tracks"].values():


        ages.append(

            track["age"]

        )


        velocities.append(

            track["velocity"]

        )



    statistics["mean_age"] = (

        np.mean(ages)

        if ages

        else 0

    )


    statistics["maximum_age"] = (

        np.max(ages)

        if ages

        else 0

    )


    statistics["mean_velocity"] = (

        np.mean(velocities)

        if velocities

        else 0

    )


    state["bubble_statistics"].update(
        statistics
    )


    return statistics
# -----------------------------------------------------------------------------
# Processing Performance Statistics
# -----------------------------------------------------------------------------
def calculate_processing_statistics(
    state=STATE
):
    """
    Calculates computational performance.

    Metrics:
        • Average FPS
        • Minimum FPS
        • Maximum FPS

    Returns
    -------
    dict
    """

    fps = np.asarray(

        state["fps_history"],

        dtype=float

    )


    if len(fps) == 0:

        return {}


    return {


        "average_fps":

            np.mean(fps),


        "minimum_fps":

            np.min(fps),


        "maximum_fps":

            np.max(fps)

    }
