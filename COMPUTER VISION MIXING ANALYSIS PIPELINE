def validate_workbook_structure(filename):
    """
    Checks that the exported workbook contains the expected
    worksheets and basic data content.

    Parameters
    ----------
    filename : str
        Path to exported workbook.


    Returns
    -------
    dict

        {
            "valid": bool,
            "missing_sheets": list,
            "warnings": list
        }

    """

    import openpyxl


    result = {

        "valid": True,

        "missing_sheets": [],

        "warnings": []

    }


    # ---------------------------------------------------------
    # Check file exists
    # ---------------------------------------------------------

    if not os.path.exists(filename):

        result["valid"] = False

        result["warnings"].append(
            "Workbook file does not exist."
        )

        return result



    # ---------------------------------------------------------
    # Open workbook
    # ---------------------------------------------------------

    try:

        workbook = openpyxl.load_workbook(
            filename,
            read_only=True
        )

    except Exception as e:

        result["valid"] = False

        result["warnings"].append(
            f"Unable to open workbook: {e}"
        )

        return result



    # ---------------------------------------------------------
    # Check sheets
    # ---------------------------------------------------------

    sheets = workbook.sheetnames


    for sheet in EXPORT_VALIDATION_CONFIG["required_sheets"]:

        if sheet not in sheets:

            result["valid"] = False

            result["missing_sheets"].append(
                sheet
            )



    workbook.close()


    return result



# -----------------------------------------------------------------------------
# Validate Worksheet Content
# -----------------------------------------------------------------------------

def validate_sheet_data(filename):
    """
    Checks that exported sheets contain data.

    Prevents accidental export of empty experiment files.
    """


    import openpyxl


    warnings = []


    workbook = openpyxl.load_workbook(
        filename,
        read_only=True
    )


    for sheet_name, minimum_rows in EXPORT_VALIDATION_CONFIG["minimum_rows"].items():


        if sheet_name not in workbook.sheetnames:

            continue


        worksheet = workbook[sheet_name]


        rows = worksheet.max_row


        if rows < minimum_rows:


            warnings.append(

                f"{sheet_name} contains insufficient data."

            )


    workbook.close()


    return warnings



# -----------------------------------------------------------------------------
# Validate Experimental Data Integrity
# -----------------------------------------------------------------------------

def validate_experiment_data():
    """
    Performs runtime validation before workbook export.

    Checks:

        • RMI measurements exist
        • Bubble tracking exists
        • Calibration exists
        • Time-series lengths match

    Returns
    -------
    dict

    """


    validation = {

        "valid": True,

        "warnings": []

    }


    # ---------------------------------------------------------
    # Time-series validation
    # ---------------------------------------------------------

    t_length = len(
        STATE["t"]
    )


    for roi_name, history in STATE["rmi_history"].items():


        if len(history) != t_length:


            validation["valid"] = False


            validation["warnings"].append(

                f"RMI history length mismatch: {roi_name}"

            )



    # ---------------------------------------------------------
    # Calibration validation
    # ---------------------------------------------------------

    if STATE["weights"] is None:


        validation["warnings"].append(

            "Calibration weights not available."

        )



    if STATE["sigma_max"] is None:


        validation["warnings"].append(

            "Sigma maximum not available."

        )



    # ---------------------------------------------------------
    # Bubble validation
    # ---------------------------------------------------------

    if len(STATE["bubble_history"]) == 0:


        validation["warnings"].append(

            "No bubble tracking data recorded."

        )



    return validation



# -----------------------------------------------------------------------------
# Complete Export Verification
# -----------------------------------------------------------------------------

def verify_workbook_export(filename):
    """
    Complete post-export verification.

    Workflow
    --------

    1. Validate workbook exists
    2. Validate worksheet structure
    3. Validate worksheet contents
    4. Report warnings


    Returns
    -------
    bool

    """


    print(
        "\n=============================="
    )

    print(
        "WORKBOOK VALIDATION"
    )

    print(
        "=============================="
    )



    # ---------------------------------------------------------
    # Structural validation
    # ---------------------------------------------------------

    structure = validate_workbook_structure(
        filename
    )


    if not structure["valid"]:


        print(
            "Workbook structure validation FAILED."
        )


        if structure["missing_sheets"]:


            print(
                "Missing sheets:"
            )


            for sheet in structure["missing_sheets"]:

                print(
                    f" - {sheet}"
                )


        return False



    print(
        "Workbook structure OK."
    )



    # ---------------------------------------------------------
    # Data validation
    # ---------------------------------------------------------

    warnings = validate_sheet_data(
        filename
    )


    if warnings:


        print(
            "\nWarnings:"
        )


        for warning in warnings:

            print(
                f" - {warning}"
            )


    else:


        print(
            "Workbook data validation OK."
        )



    # ---------------------------------------------------------
    # Runtime state validation
    # ---------------------------------------------------------

    experiment_validation = validate_experiment_data()


    if not experiment_validation["valid"]:


        print(
            "\nExperiment validation FAILED."
        )


    for warning in experiment_validation["warnings"]:

        print(
            f" - {warning}"
        )



    print(
        "\nWorkbook verification complete."
    )


    return True

