def create_grayscale_frame(frame):
    """
    Converts the incoming frame into the optimised grayscale image
    using the calibration weights.

    Returns
    -------
    ndarray
    """

    if STATE["weights"] is None:
        return cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

    return grayscale_with_weights(
        frame,
        STATE["weights"]
    )


