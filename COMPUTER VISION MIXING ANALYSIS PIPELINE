import math


class BubbleDetector:
    """
    High-level bubble detector.

    Workflow
    --------
        Outlet ROI
            │
            ▼
        BubblePreprocessor
            │
            ▼
        BubbleSegmenter
            │
            ▼
        Feature Extraction
            │
            ▼
        BubbleDetection objects

    Tracking is NOT performed here.
    """

    # -------------------------------------------------------------------------
    # Constructor
    # -------------------------------------------------------------------------

    def __init__(
        self,
        config: BubbleDetectorConfig
    ):

        self.config = config

        self.preprocessor = BubblePreprocessor(config)

        self.segmenter = BubbleSegmenter(config)

    # =========================================================================
    # Feature Extraction Helpers
    # =========================================================================

    @staticmethod
    def contour_area(contour):
        """Returns contour area."""

        return float(cv2.contourArea(contour))

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_perimeter(contour):
        """Returns contour perimeter."""

        return float(
            cv2.arcLength(
                contour,
                True
            )
        )

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_centroid(contour):
        """
        Calculates contour centroid.

        Returns
        -------
        (x, y)
        """

        moments = cv2.moments(contour)

        if moments["m00"] == 0:

            return (0, 0)

        cx = int(
            moments["m10"] /
            moments["m00"]
        )

        cy = int(
            moments["m01"] /
            moments["m00"]
        )

        return (cx, cy)

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_bounding_box(contour):
        """
        Returns

            (x, y, w, h)
        """

        return cv2.boundingRect(contour)

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_equivalent_diameter(area):
        """
        Diameter of a circle having the same area.
        """

        return math.sqrt(
            4.0 * area / math.pi
        )

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_circularity(
        area,
        perimeter
    ):
        """
        Circularity

            1 = perfect circle
        """

        if perimeter == 0:

            return 0.0

        return float(

            4.0
            * math.pi
            * area

        ) / (perimeter ** 2)

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_solidity(contour):
        """
        Solidity

        Area / Convex Hull Area
        """

        hull = cv2.convexHull(contour)

        hull_area = cv2.contourArea(hull)

        if hull_area == 0:

            return 0.0

        return float(

            cv2.contourArea(contour)

            /

            hull_area

        )

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_extent(
        area,
        bounding_box
    ):
        """
        Extent

        Area / Bounding Box Area
        """

        _, _, w, h = bounding_box

        if w * h == 0:

            return 0.0

        return float(

            area /

            (w * h)

        )

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_aspect_ratio(
        bounding_box
    ):
        """
        Width / Height
        """

        _, _, w, h = bounding_box

        if h == 0:

            return 0.0

        return float(w / h)

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_orientation(contour):
        """
        Major axis orientation.

        Returns

            angle (degrees)

        Requires at least five contour points.
        """

        if len(contour) < 5:

            return 0.0

        (_, _), (_, _), angle = cv2.fitEllipse(
            contour
        )

        return float(angle)

    # -------------------------------------------------------------------------

    @staticmethod
    def contour_ellipse_axes(contour):
        """
        Returns

            major_axis,
            minor_axis
        """

        if len(contour) < 5:

            return (0.0, 0.0)

        (_, _), (major, minor), _ = cv2.fitEllipse(
            contour
        )

        return (

            float(major),

            float(minor)

        )

    # =========================================================================
    # Detection Confidence
    # =========================================================================

    def confidence(
        self,
        circularity,
        solidity,
        extent
    ):
        """
        Estimates detector confidence.

        Returns

            0.0 – 1.0
        """

        score = (

            0.45 * circularity +

            0.35 * solidity +

            0.20 * extent

        )

        return float(

            np.clip(

                score,

                0.0,

                1.0

            )

        )

    # =========================================================================
    # Bubble Object Creation
    # =========================================================================

    def create_detection(
        self,
        contour
    ):
        """
        Converts one contour into a BubbleDetection object.
        """

        area = self.contour_area(contour)

        perimeter = self.contour_perimeter(contour)

        centroid = self.contour_centroid(contour)

        bbox = self.contour_bounding_box(contour)

        circularity = self.contour_circularity(

            area,

            perimeter

        )

        solidity = self.contour_solidity(

            contour

        )

        extent = self.contour_extent(

            area,

            bbox

        )

        aspect_ratio = self.contour_aspect_ratio(

            bbox

        )

        equivalent_diameter = (

            self.contour_equivalent_diameter(

                area

            )

        )

        orientation = self.contour_orientation(

            contour

        )

        major_axis, minor_axis = (

            self.contour_ellipse_axes(

                contour

            )

        )

        confidence = self.confidence(

            circularity,

            solidity,

            extent

        )

        detection = BubbleDetection(

            id=None,

            contour=contour,

            centroid=centroid,

            bounding_box=bbox,

            area=area,

            perimeter=perimeter,

            equivalent_diameter=equivalent_diameter,

            circularity=circularity,

            solidity=solidity,

            extent=extent,

            aspect_ratio=aspect_ratio,

            orientation=orientation,

            major_axis=major_axis,

            minor_axis=minor_axis,

            confidence=confidence,

            validated=False,

            accepted=False,

            timestamp=0.0

        )

        return detection

    # =========================================================================
    # Multiple Detection Creation
    # =========================================================================

    def create_detections(
        self,
        contours
    ):
        """
        Converts all accepted contours into BubbleDetection
        objects.
        """

        detections = []

        for contour in contours:

            detections.append(

                self.create_detection(

                    contour

                )

            )

        return detections
    
# =============================================================================
# SECTION 6.2C (PART 2)
# COMPLETE DETECTION PIPELINE
# =============================================================================

    # =========================================================================
    # Frame Statistics
    # =========================================================================

    @staticmethod
    def compute_statistics(detections):
        """
        Computes frame-level bubble statistics.

        Returns
        -------
        dict
        """

        if len(detections) == 0:

            return {

                "count": 0,
                "total_area": 0.0,
                "mean_area": 0.0,
                "median_area": 0.0,
                "std_area": 0.0,
                "largest_area": 0.0,
                "smallest_area": 0.0,
                "mean_diameter": 0.0,
                "mean_confidence": 0.0

            }

        areas = np.array(

            [d.area for d in detections],

            dtype=np.float32

        )

        diameters = np.array(

            [

                d.equivalent_diameter

                for d in detections

            ],

            dtype=np.float32

        )

        confidence = np.array(

            [

                d.confidence

                for d in detections

            ],

            dtype=np.float32

        )

        return {

            "count": len(detections),

            "total_area": float(np.sum(areas)),

            "mean_area": float(np.mean(areas)),

            "median_area": float(np.median(areas)),

            "std_area": float(np.std(areas)),

            "largest_area": float(np.max(areas)),

            "smallest_area": float(np.min(areas)),

            "mean_diameter": float(

                np.mean(

                    diameters

                )

            ),

            "mean_confidence": float(

                np.mean(

                    confidence

                )

            )

        }

    # =========================================================================
    # Complete Bubble Detection
    # =========================================================================

    def detect(
        self,
        outlet_roi,
        calibration=None,
        timestamp=0.0
    ):
        """
        Complete bubble detection pipeline.

        Parameters
        ----------
        outlet_roi : ndarray

        calibration : CalibrationResults | None

        timestamp : float

        Returns
        -------
        BubbleDetectionResults
        """

        # ---------------------------------------------------------
        # Preprocessing
        # ---------------------------------------------------------

        preprocessing = self.preprocessor.preprocess(

            outlet_roi,

            calibration

        )

        processed = preprocessing["processed"]

        # ---------------------------------------------------------
        # Segmentation
        # ---------------------------------------------------------

        segmentation = self.segmenter.segment(

            processed

        )

        accepted_contours = (

            segmentation["accepted_contours"]

        )

        # ---------------------------------------------------------
        # Feature Extraction
        # ---------------------------------------------------------

        detections = self.create_detections(

            accepted_contours

        )

        # ---------------------------------------------------------
        # Timestamp each detection
        # ---------------------------------------------------------

        for detection in detections:

            detection.timestamp = timestamp

        # ---------------------------------------------------------
        # Frame Statistics
        # ---------------------------------------------------------

        statistics = self.compute_statistics(

            detections

        )

        # ---------------------------------------------------------
        # Build Result Object
        # ---------------------------------------------------------

        results = BubbleDetectionResults(

            timestamp=timestamp,

            detections=detections,

            statistics=statistics,

            preprocessing=preprocessing,

            segmentation=segmentation

        )

        return results
    
