        ]
    )



    def add_roi(
        self,
        roi: ROIDefinition
    ):
        """
        Adds an ROI definition.
        """

        self.rois[roi.name] = roi



    def get_roi(
        self,
        name: str
    ) -> Optional[ROIDefinition]:
        """
        Returns a named ROI.
        """

        return self.rois.get(name)



    def all_coordinates(self) -> Dict[str, tuple]:
        """
        Returns all ROI coordinates.

        Returns
        -------
        dict

            {
                "Interface":
                    (y1,y2,x1,x2)
            }
        """

        coordinates = {}


        for name, roi in self.rois.items():

            if roi.coordinates is None:

                roi.calculate_coordinates()


            coordinates[name] = roi.coordinates


        return coordinates



