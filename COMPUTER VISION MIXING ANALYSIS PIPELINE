class BubblePreprocessor:
    """
    Image preprocessing prior to thresholding.
    """

    def __init__(
        self,
        config: BubbleDetectorConfig
    ):

        self.config = config

    # =========================================================================
    # Grayscale Conversion
    # =========================================================================

    def grayscale(
        self,
        image,
        calibration=None
    ):
        """
        Converts an image to grayscale.

        Supports either:

            • OpenCV grayscale

            • Custom calibrated grayscale
        """

        if self.config.grayscale_method == "custom":

            if calibration is None:

                raise ValueError(
                    "Calibration required for custom grayscale."
                )

            return grayscale_with_weights(

                image,

                calibration.weights

            )

        return cv2.cvtColor(

            image,

            cv2.COLOR_BGR2GRAY

        )

    # =========================================================================
    # Gaussian Blur
    # =========================================================================

    def gaussian_blur(
        self,
        image
    ):
        """
        Applies Gaussian smoothing.
        """

        kernel = self.config.gaussian_kernel

        if kernel % 2 == 0:
            kernel += 1

        return cv2.GaussianBlur(

            image,

            (kernel, kernel),

            self.config.gaussian_sigma

        )

    # =========================================================================
    # Histogram Equalisation
    # =========================================================================

    def equalise(
        self,
        image
    ):
        """
        Performs standard histogram equalisation.
        """

        if not self.config.equalise_histogram:

            return image

        return cv2.equalizeHist(image)

    # =========================================================================
    # CLAHE
    # =========================================================================

    def clahe(
        self,
        image
    ):
        """
        Applies Contrast Limited Adaptive Histogram Equalisation.
        """

        if not self.config.use_clahe:

            return image

        clahe = cv2.createCLAHE(

            clipLimit=self.config.clahe_clip_limit,

            tileGridSize=(

                self.config.clahe_grid_size,

                self.config.clahe_grid_size

            )

        )

        return clahe.apply(image)

    # =========================================================================
    # Morphology
    # =========================================================================

    def morphology(
        self,
        image
    ):
        """
        Performs morphology to reduce noise.

        Supported operations

            • open

            • close

            • erode

            • dilate
        """

        if not self.config.morphology_enabled:

            return image

        kernel = np.ones(

            (

                self.config.morphology_kernel,

                self.config.morphology_kernel

            ),

            np.uint8

        )

        operation = self.config.morphology_operation.lower()

        if operation == "open":

            return cv2.morphologyEx(

                image,

                cv2.MORPH_OPEN,

                kernel,

                iterations=self.config.morphology_iterations

            )

        elif operation == "close":

            return cv2.morphologyEx(

                image,

                cv2.MORPH_CLOSE,

                kernel,

                iterations=self.config.morphology_iterations

            )

        elif operation == "erode":

            return cv2.erode(

                image,

                kernel,

                iterations=self.config.morphology_iterations

            )

        elif operation == "dilate":

            return cv2.dilate(

                image,

                kernel,

                iterations=self.config.morphology_iterations

            )

        return image

    # =========================================================================
    # Complete Preprocessing Pipeline
    # =========================================================================

    # Somewhere accessible (e.g., Section 6.2 or a utils module)
def preprocess_frame(frame, state):
    """
    Wrapper to run the BubblePreprocessor pipeline.
    """
    preproc = BubblePreprocessor(state.bubble_config)

    # Example pipeline: grayscale → blur
    gray = preproc.grayscale(frame)
    blurred = preproc.gaussian_blur(gray)

    return blurred


