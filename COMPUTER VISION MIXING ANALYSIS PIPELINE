# =============================================================================
# 7.1 Text Rendering Helper
# =============================================================================
def put_text(
    image,
    text,
    position,
    colour=(255,255,255),
    scale=0.6,
    thickness=1
):
    """
    Draw anti-aliased text.

    Used by all visualisation functions.
    """


    cv2.putText(

        image,

        text,

        position,

        cv2.FONT_HERSHEY_DUPLEX,

        scale,

        colour,

        thickness,

        cv2.LINE_AA

    )


    return image

# =============================================================================
# 7.2 ROI Drawing Functions
# =============================================================================
def draw_single_roi(
    image,
    roi,
    name,
    colour=None
):
    """
    Draw one ROI rectangle.

    Parameters
    ----------
    roi:

        (y1,y2,x1,x2)

    """


    if colour is None:

        colour = COLOURS["ROI"]



    y1,y2,x1,x2 = roi



    cv2.rectangle(

        image,

        (x1,y1),

        (x2,y2),

        colour,

        2

    )


    put_text(

        image,

        name,

        (x1,y1-8),

        colour,

        0.5,

        1

    )


    return image

# =============================================================================
# Draw all experiement ROIs
# =============================================================================
def draw_all_rois(
    frame,
    enabled=True
):
    """
    Draw Interface → Mixer4 → Outlet ROIs.
    """


    if not enabled:

        return frame



    for name, roi in STATE["rois"].items():


        draw_single_roi(

            frame,

            roi,

            name

        )


    return frame

# =============================================================================
# Bubble drawing
# =============================================================================

def draw_bubble_detection(
    outlet_image,
    bubble_results,
    show_ids=True,
    show_contours=True
):
    """
    Draw bubble detections on outlet ROI.

    Used in Q3.
    """


    if bubble_results is None:

        return outlet_image



    for bubble in bubble_results.detections:


        contour = bubble.contour



        if show_contours:


            cv2.drawContours(

                outlet_image,

                [contour],

                -1,

                COLOURS["BUBBLE"],

                1

            )



        cx,cy = bubble.centroid



        cv2.circle(

            outlet_image,

            (cx,cy),

            3,

            COLOURS["CENTROID"],

            -1

        )



        if show_ids:


            put_text(

                outlet_image,

                f"ID:{bubble.track_id}",

                (cx+5,cy),

                COLOURS["TEXT"],

                0.45,

                1

            )



    return outlet_image

# =============================================================================
# 7.4 Bubble Trajectory Drawing
# =============================================================================
def draw_tracks(
    image,
    tracks,
    enabled=True
):
    """
    Draw bubble movement histories.
    """


    if not enabled:

        return image



    for track in tracks.values():


        history = track.trajectory



        if len(history)<2:

            continue



        for i in range(1,len(history)):


            cv2.line(

                image,

                history[i-1],

                history[i],

                COLOURS["TRACK"],

                1

            )



    return image

# =============================================================================
# 7.5 Q1 Video Display Renderer
# =============================================================================
def render_video_frame(
    frame,
    bubble_results=None,
    show_rois=True,
    show_tracks=True
):
    """
    Creates final Q1 display frame.

    Returns
    -------
    ndarray
    """


    display = frame.copy()



    # ROIs

    display = draw_all_rois(

        display,

        show_rois

    )



    # Bubble overlays

    if bubble_results:


        outlet_roi = extract_roi(

            display,

            STATE["rois"]["Outlet"]

        )


        outlet_roi = draw_bubble_detection(

            outlet_roi,

            bubble_results

        )



    # Tracks

    display = draw_tracks(

        display,

        STATE["tracks"],

        show_tracks

    )



    return display

