# SECTION 3.6
# CALIBRATION CONTROLLER
# =============================================================================
#
# Connects the PyQt5 calibration interface with the image-processing
# calibration mathematics.
#
# Responsibilities:
#
#   • Extract calibration patches
#   • Calculate RGB intensities
#   • Optimise grayscale conversion weights
#   • Calculate sigma reference
#   • Store final calibration result
#
# GUI classes do not perform calculations.
#
# Processing functions do not control GUI elements.
#
# =============================================================================


# =============================================================================
# Calibration Controller
# =============================================================================


class CalibrationController(QObject):
    """
    Controls the complete calibration process.

    Receives:

        CalibrationState

        Calibration points

        Reference frame


    Returns:

        Updated CalibrationState

    """


    calibration_finished = pyqtSignal(
        CalibrationState
    )


    calibration_failed = pyqtSignal(
        str
    )



    def __init__(
        self,
        calibration_state: CalibrationState
    ):

        super().__init__()


        self.state = calibration_state



    # -------------------------------------------------------------------------
    # Run Calibration
    # -------------------------------------------------------------------------

    def perform_calibration(
        self,
        frame,
        patch_size=40
    ):
        """
        Performs calibration calculations.

        Parameters
        ----------
        frame :
            Calibration frame.

        patch_size :
            Size of RGB sampling patches.


        Returns
        -------
        CalibrationState
        """


        try:


            points = (

                self.state
                .calibration
                .calibration_points

            )


            if (

                "Blue Fluid" not in points

                or

                "Yellow Fluid" not in points

            ):

                raise ValueError(

                    "Missing calibration points."

                )



            # -------------------------------------------------------------
            # Extract RGB values
            # -------------------------------------------------------------

            blue_rgb = (

                self.get_patch_rgb(

                    frame,

                    points["Blue Fluid"]

                )

            )


            yellow_rgb = (

                self.get_patch_rgb(

                    frame,

                    points["Yellow Fluid"]

                )

            )



            # -------------------------------------------------------------
            # Optimise grayscale weights
            # -------------------------------------------------------------

            weights, score = (

                self.optimise_weights(

                    blue_rgb,

                    yellow_rgb

                )

            )



            # -------------------------------------------------------------
            # Calculate sigma reference
            # -------------------------------------------------------------

            sigma_max = (

                self.calculate_sigma_max(

                    frame,

                    points["Blue Fluid"],

                    points["Yellow Fluid"],

                    weights,

                    patch_size

                )

            )



            # -------------------------------------------------------------
            # Store calibration result
            # -------------------------------------------------------------

            calibration = (

                self.state.calibration

            )


            calibration.weights = weights


            calibration.sigma_reference = sigma_max


            calibration.separation_score = score



            calibration.fluid_intensities = {


                "Blue Fluid":

                    float(
                        np.dot(
                            blue_rgb,
                            weights
                        )
                    ),


                "Yellow Fluid":

                    float(
                        np.dot(
                            yellow_rgb,
                            weights
                        )
                    )


            }



            calibration.calibrated = True



            self.calibration_finished.emit(
                self.state
            )


            return self.state



        except Exception as error:


            self.calibration_failed.emit(

                str(error)

            )


            raise error



    # -------------------------------------------------------------------------
    # Extract RGB Patch
    # -------------------------------------------------------------------------

    def get_patch_rgb(
        self,
        frame,
        point
    ):
        """
        Extracts mean RGB intensity.

        Uses the existing ROI utility.
        """


        return get_patch_mean_rgb(

            frame,

            (
                point.x,

                point.y

            ),

            point.patch_size

        )



    # -------------------------------------------------------------------------
    # Optimise RGB Weights
    # -------------------------------------------------------------------------

    def optimise_weights(
        self,
        blue_rgb,
        yellow_rgb
    ):
        """
        Searches RGB weighting combinations.

        Weight equation:

            Gray =
                R*wR +
                G*wG +
                B*wB


        Constraints:

            wR+wG+wB = 1

        """


        best_score = -np.inf


        best_weights = None



        step = 0.05



        for r in np.arange(
            0,
            1 + step,
            step
        ):


            for g in np.arange(

                0,

                1-r+step,

                step

            ):


                b = 1-r-g



                if b < 0:

                    continue



                weights = np.array(

                    [
                        r,
                        g,
                        b
                    ]

                )



                blue_gray = (

                    np.dot(

                        blue_rgb,

                        weights

                    )

                )


                yellow_gray = (

                    np.dot(

                        yellow_rgb,

                        weights

                    )

                )



                score = abs(

                    blue_gray

                    -

                    yellow_gray

                )



                if score > best_score:


                    best_score = score


                    best_weights = tuple(
                        weights
                    )



        return (

            best_weights,

            float(best_score)

        )



    # -------------------------------------------------------------------------
    # Sigma Max Calculation
    # -------------------------------------------------------------------------

    def calculate_sigma_max(
        self,
        frame,
        fluid1,
        fluid2,
        weights,
        patch_size
    ):
        """
        Calculates theoretical maximum sigma.

        Creates synthetic unmixed interface:

            Fluid 1 pixels
                    +
            Fluid 2 pixels

        """



        def extract_patch(point):


            roi = extract_roi(

                frame,

                (

                    point.y -
                    patch_size//2,


                    point.y +
                    patch_size//2,


                    point.x -
                    patch_size//2,


                    point.x +
                    patch_size//2

                )

            )



            gray = grayscale_with_weights(

                roi,

                weights

            )


            return gray.flatten()



        patch1 = extract_patch(
            fluid1
        )


        patch2 = extract_patch(
            fluid2
        )



        length = min(

            len(patch1),

            len(patch2)

        )



        synthetic_interface = np.concatenate(

            [

                patch1[:length],

                patch2[:length]

            ]

        )



        return float(

            np.std(
                synthetic_interface
            )

        )
    
