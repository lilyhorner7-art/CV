# =============================================================================
# ROI Geometry
# =============================================================================

def roi_from_center(
    centre,
    width,
    height
):
    """
    Creates an ROI from its centre coordinate.

    Returns

        (y1,y2,x1,x2)

    """

    x,y = centre

    half_w = width//2

    half_h = height//2

    return (

        y-half_h,

        y+half_h,

        x-half_w,

        x+half_w

    )

