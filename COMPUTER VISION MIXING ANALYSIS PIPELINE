def build_rmi_dataframe(state=STATE):
    """
    Creates the frame-by-frame RMI dataset.

    Contains:
        • Frame number
        • Time
        • RMI values
        • Sigma values
        • Processing FPS

    Returns
    -------
    pandas.DataFrame
    """

    rows = []

    length = len(
        state["t"]
    )


    for i in range(length):

        row = {

            "Frame":
                i + 1,

            "Time (s)":
                state["t"][i],

        }


        # ---------------------------------------------------------
        # RMI values
        # ---------------------------------------------------------

        for roi_name, history in state["rmi_history"].items():

            if i < len(history):

                row[
                    f"{roi_name} RMI"
                ] = history[i]



        # ---------------------------------------------------------
        # Sigma values
        # ---------------------------------------------------------

        for roi_name, history in state["sigma_history"].items():

            if i < len(history):

                row[
                    f"{roi_name} Sigma"
                ] = history[i]


        # ---------------------------------------------------------
        # Processing speed
        # ---------------------------------------------------------

        if i < len(state["fps_history"]):

            row["FPS"] = (
                state["fps_history"][i]
            )


        rows.append(row)


    return pd.DataFrame(rows)
# -----------------------------------------------------------------------------
# 11.2.2 Bubble Tracking DataFrame
# -----------------------------------------------------------------------------
def build_bubble_tracking_dataframe(
    bubble_rows=None
):
    """
    Creates the individual bubble tracking dataset.

    Each row represents one detected bubble
    at one specific frame.

    Columns include:
        • Frame
        • Time
        • Bubble ID
        • Position
        • Area
        • Velocity
        • Age
        • Shape information

    Returns
    -------
    pandas.DataFrame
    """

    if bubble_rows is None:

        bubble_rows = STATE["bubble_rows"]


    records = []


    for frame_data in bubble_rows:


        frame = frame_data["frame"]

        time = frame_data["time"]


        bubbles = frame_data["bubbles"]


        ids = bubbles["ids"]

        areas = bubbles["areas"]

        centroids = bubbles["centroids"]

        velocities = bubbles["velocities"]

        ages = bubbles["ages"]

        circularities = bubbles["circularities"]


        for i, bubble_id in enumerate(ids):

            centroid = centroids[i]


            records.append({

                "Frame":
                    frame,

                "Time (s)":
                    time,

                "Bubble ID":
                    bubble_id,

                "Centroid X":
                    centroid[0],

                "Centroid Y":
                    centroid[1],

                "Area (pixels²)":
                    areas[i],

                "Velocity (pixels/frame)":
                    velocities[i],

                "Age (frames)":
                    ages[i],

                "Circularity":
                    circularities[i]

            })


    return pd.DataFrame(records)
