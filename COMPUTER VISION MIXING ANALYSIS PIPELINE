# Extract Colour ROIs
# -----------------------------------------------------------------------------

def extract_colour_rois(frame):
    """
    Extracts every processing ROI from the original colour frame.

    Returns
    -------
    dict
    """

    roi_images = {}

    for roi_name, roi in STATE["rois"].items():

        roi_images[roi_name] = extract_roi(
            frame,
            roi
        )

    return roi_images


