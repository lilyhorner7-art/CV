def create_panel(width, height, colour=None):
    """
    Creates an empty dashboard panel.
    """

    if colour is None:
        colour = DASHBOARD_CONFIG["background_colour"]

    panel = np.full(
        (height, width, 3),
        colour,
        dtype=np.uint8
    )

    return panel


# -----------------------------------------------------------------------------
# Helper
# -----------------------------------------------------------------------------

def fit_image(image, size):
    """
    Resizes an image while preserving aspect ratio.
    """

    width, height = size

    if image is None:

        return create_panel(width, height)

    h, w = image.shape[:2]

    scale = min(width / w, height / h)

    new_w = max(1, int(w * scale))
    new_h = max(1, int(h * scale))

    resized = cv2.resize(
        image,
        (new_w, new_h),
        interpolation=cv2.INTER_AREA
    )

    if len(resized.shape) == 2:

        resized = cv2.cvtColor(
            resized,
            cv2.COLOR_GRAY2BGR
        )

    canvas = create_panel(width, height)

    x = (width - new_w) // 2
    y = (height - new_h) // 2

    canvas[
        y:y + new_h,
        x:x + new_w
    ] = resized

    return canvas


