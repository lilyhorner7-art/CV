        default_factory=dict
    )


    calibration_points: Dict[str, CalibrationPoint] = field(
        default_factory=dict
    )


    timestamp: str = field(
        default_factory=lambda:
        datetime.now().strftime(
            "%Y-%m-%d %H:%M:%S"
        )
    )


    calibrated: bool = False



    def is_valid(self) -> bool:
        """
        Checks whether calibration has successfully completed.

        Returns
        -------
        bool
        """

        return (

            self.weights is not None

            and

            self.sigma_reference is not None

            and

            self.calibrated

        )



# =============================================================================
# ROI Definition
# =============================================================================

@dataclass
class ROIDefinition:
    """
    Stores a single experimental Region Of Interest.

    ROI coordinates use:

        (y1, y2, x1, x2)

    because they directly match NumPy image slicing.
    """


    name: str


    centre: Tuple[int, int]


    width: int


    height: int


    coordinates: Optional[
        Tuple[int, int, int, int]
    ] = None



    def calculate_coordinates(self):
        """
        Converts centre coordinates into NumPy ROI format.
        """

        x, y = self.centre


        half_width = self.width // 2

        half_height = self.height // 2


        self.coordinates = (

            y - half_height,

            y + half_height,

            x - half_width,

            x + half_width

        )


        return self.coordinates



