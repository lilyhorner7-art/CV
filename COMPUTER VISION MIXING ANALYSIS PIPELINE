def build_dashboard(displays):
    """
    Creates the complete Version 6 dashboard.

    Returns
    -------
    dashboard : ndarray
    """

    width = DASHBOARD_CONFIG["quadrant_width"]
    height = DASHBOARD_CONFIG["quadrant_height"]

    # ---------------------------------------------------------
    # Q1
    # ---------------------------------------------------------

    q1 = fit_image(
        displays["Main Frame"],
        (width, height)
    )

    add_panel_title(
        q1,
        "Q1 - Live Video"
    )

    # ---------------------------------------------------------
    # Q2
    # ---------------------------------------------------------

    q2 = fit_image(
        displays["RMI Plot"],
        (width, height)
    )

    add_panel_title(
        q2,
        "Q2 - RMI vs Time"
    )

    # ---------------------------------------------------------
    # Q3
    # ---------------------------------------------------------

    outlet = fit_image(
        displays["Outlet ROI"],
        (width, int(height * 0.60))
    )

    bubble_plot = fit_image(
        displays["Bubble Plot"],
        (width, int(height * 0.40))
    )

    q3 = np.vstack([
        outlet,
        bubble_plot
    ])

    add_panel_title(
        q3,
        "Q3 - Bubble Analysis"
    )

    # ---------------------------------------------------------
    # Q4
    # ---------------------------------------------------------

    roi_images = []

    for name in [
        "Interface",
        "Mixer 1",
        "Mixer 2",
        "Mixer 3",
        "Mixer 4"
    ]:

        roi = displays["ROI Displays"][name]

        roi = fit_image(
            roi,
            (170, 420)
        )

        put_text(

            roi,

            name,

            (8, 25),

            (255, 255, 255),

            scale=0.55,

            thickness=1

        )

        roi_images.append(roi)

    q4 = np.hstack(roi_images)

    q4 = cv2.resize(
        q4,
        (width, height)
    )

    add_panel_title(
        q4,
        "Q4 - Mixing Progression"
    )

    # ---------------------------------------------------------
    # Assemble Dashboard
    # ---------------------------------------------------------

    top = np.hstack([q1, q2])

    bottom = np.hstack([q4, q3])

    dashboard = np.vstack([top, bottom])

    return dashboard
