class ProcessingTimer:
    """
    High-resolution processing timer used to calculate
    instantaneous processing FPS.
    """

    def __init__(self):

        self.start_time = None

    def start(self):

        self.start_time = time.perf_counter()

    def stop(self):

        elapsed = time.perf_counter() - self.start_time

        if elapsed <= 0:
            return 0.0

        return 1.0 / elapsed


